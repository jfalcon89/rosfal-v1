<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gran Rifa de las Madres</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen font-sans">

    <div class="container mx-auto px-4 py-8 max-w-6xl">

        <header class="relative mb-10 bg-gradient-to-br from-gray-900 via-zinc-900 to-stone-900 p-6 md:p-8 rounded-3xl shadow-xl border border-zinc-800 overflow-hidden text-white">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-pink-600/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-amber-500/10 rounded-full blur-3xl pointer-events-none"></div>

            <div class="flex flex-col md:flex-row items-center justify-between gap-6 relative z-10">

                <div class="text-center md:text-left space-y-4 max-w-2xl flex-1">
                    <div class="inline-flex items-center space-x-2 bg-pink-500/10 text-pink-400 text-xs font-bold px-3 py-1.5 rounded-full border border-pink-500/20 uppercase tracking-wider">
                        <span>✨ Evento Especial</span>
                    </div>
                    <a href="/rifa_listado" class="inline-flex items-center space-x-2 bg-zinc-800/90 hover:bg-zinc-700/90 text-zinc-300 hover:text-white border border-zinc-700/60 px-3 py-1.5 rounded-full text-xs font-bold transition-all duration-300 shadow-md">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
                    </svg>
                        <span>Ver Listado y Reportes</span>
                    </a>
                    <a href="/logout" class="inline-flex items-center space-x-2 bg-rose-500/10 hover:bg-rose-600 text-rose-400 hover:text-white border border-rose-500/20 hover:border-rose-600 px-3 py-1.5 rounded-full text-xs font-bold transition-all duration-300 shadow-md group">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-rose-400 group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
                        <span>Cerrar Sesión</span>
                    </a>

                    <h1 class="text-3xl md:text-5xl font-black tracking-tight bg-gradient-to-r from-pink-500 via-rose-400 to-amber-400 bg-clip-text text-transparent drop-shadow-sm">
                        Gran Rifa del Día de las Madres
                    </h1>

                    <p class="text-zinc-400 text-base md:text-lg font-medium flex items-center justify-center md:justify-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                        <span>Domingo 31 de Mayo</span>
                    </p>

                    <div class="pt-2 flex flex-wrap gap-3 justify-center md:justify-start items-center">
                        <div class="bg-zinc-800/80 backdrop-blur border border-zinc-700 px-4 py-2 rounded-2xl shadow-inner">
                            <span class="text-zinc-400 text-xs font-semibold block uppercase tracking-wider">Boleto</span>
                            <span class="text-xl font-black text-white">RD$ 100</span>
                        </div>

                        <div class="bg-amber-500/10 backdrop-blur border border-amber-500/30 px-4 py-2 rounded-2xl shadow-inner">
                            <span class="text-amber-400 text-xs font-semibold block uppercase tracking-wider">Premio Especial</span>
                            <span class="text-base font-extrabold text-amber-300">Johnnie Walker Double Black</span>
                        </div>
                    </div>
                </div>

                <div class="flex-shrink-0 w-full md:w-auto flex justify-center">
                    <div class="relative group">
                        <div class="absolute inset-0 bg-gradient-to-t from-amber-500/20 to-pink-500/20 rounded-2xl blur-xl opacity-80 group-hover:opacity-100 transition duration-500"></div>

                        <div class="relative bg-zinc-800/50 p-4 rounded-2xl border border-zinc-700/60 backdrop-blur-sm shadow-2xl max-w-[200px] md:max-w-[220px]">
                            <img src="/img/premio.png" alt="Johnnie Walker Double Black" class="w-full h-auto object-contain transform group-hover:scale-105 transition duration-500 rounded-lg">
                            <div class="absolute bottom-2 left-1/2 transform -translate-x-1/2 w-4/5 bg-black/70 backdrop-blur border border-zinc-700 py-1 px-2 rounded-full text-center shadow-md">
                                <p class="text-[10px] font-black tracking-widest text-amber-400 uppercase">El Premio 🏆</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </header>

        <form id="formRifa" class="space-y-6">

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <% for(let i = 1; i <= 100; i++) { %>
                    <% 
        // Tu lógica de negocio impecable (Exactamente igual)
        let nombre = '';
        let pagado = false;

        if (typeof mapaBoletos !== 'undefined' && mapaBoletos[String(i)]) {
            nombre = mapaBoletos[String(i)].nombre;
            const estadoLimpio = String(mapaBoletos[String(i)].estado).toLowerCase().trim();
            pagado = (estadoLimpio === 'pagado' || estadoLimpio === 'pago' || estadoLimpio === '1' || estadoLimpio === 'true');
        }

        // Definimos las clases y estados base iniciales del servidor (Exactamente igual)
        let claseCardBase = 'bg-white border-gray-200';
        let claseNumeroBase = 'bg-gray-100 text-gray-700';
        let claseBotonBase = 'bg-gray-200 text-gray-500 border-gray-300';

        if (nombre !== '') {
            if (pagado) {
                claseCardBase = 'bg-emerald-50 border-emerald-300 shadow-sm';
                claseNumeroBase = 'bg-emerald-600 text-white';
                claseBotonBase = 'bg-emerald-600 text-white border-emerald-700';
            } else {
                claseCardBase = 'bg-amber-50 border-amber-300 has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-300';
                claseNumeroBase = 'bg-amber-600 text-white has-~-[:checked]:bg-emerald-600';
                claseBotonBase = 'bg-gray-200 text-gray-500 border-gray-300 peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-700';
            }
        }
    %>

                        <div class="p-4 rounded-xl border flex flex-col justify-between transition-all duration-300 hover:shadow-md <%= claseCardBase %>">

                            <div class="flex justify-between items-center mb-3">
                                <span class="text-xl font-black h-9 w-9 flex items-center justify-center rounded-full transition-colors duration-300 <%= claseNumeroBase %>">
                <%= String(i).padStart(2, '0') %>
            </span>

                                <label class="relative flex items-center cursor-pointer select-none">
                <input type="checkbox" 
                       name="pago_<%= i %>" 
                       class="sr-only peer" 
                       <%= pagado ? 'checked' : '' %>>
                
                <div class="w-24 h-7 rounded-full text-[11px] font-bold uppercase tracking-wider flex items-center justify-center border transition-all duration-300 select-none <%= claseBotonBase %> 
                            <%= pagado ? 'peer-not-checked:bg-gray-200 peer-not-checked:text-gray-500 peer-not-checked:border-gray-300' : 'peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-700' %>">
                    
                    <% if (nombre === '') { %>
                        <span class="text-gray-400 font-semibold tracking-normal lowercase first-letter:uppercase">Disponible</span>
                    <% } else { %>
                        <% if (pagado) { %>
                            <span class="peer-not-checked:inline hidden">⏳ Espera</span>
                            <span class="peer-not-checked:hidden inline">✅ Pagado</span>
                        <% } else { %>
                            <span class="peer-checked:hidden inline">⏳ Espera</span>
                            <span class="peer-checked:inline hidden">✅ Pagado</span>
                        <% } %>
                    <% } %>
                    
                </div>
            </label>
                            </div>

                            <div>
                                <input type="text" name="nombre_<%= i %>" value="<%= nombre %>" placeholder="Disponible" class="w-full px-3 py-2 text-sm bg-white/80 backdrop-blur-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 focus:bg-white transition-all font-medium">
                            </div>
                        </div>
                        <% } %>
            </div>

            <div class="sticky bottom-6 flex justify-center sticky-submit">
                <button type="submit" class="bg-gradient-to-r from-pink-600 to-rose-500 hover:from-pink-700 hover:to-rose-600 text-white font-bold text-lg px-8 py-4 rounded-full shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all flex items-center space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                    </svg>
                    <span>Guardar Todos los Datos</span>
                </button>
            </div>

        </form>
    </div>

    <script>
        document.getElementById('formRifa').addEventListener('submit', async(e) => {
            e.preventDefault();

            const formData = new FormData(e.target);
            const datosRifa = [];

            // Recorremos los 100 números para evaluar qué enviar
            for (let i = 1; i <= 100; i++) {
                // Evaluamos si el input existe en el DOM antes de leerlo
                const inputNombre = formData.get(`nombre_${i}`);
                if (inputNombre === null) continue; // Si no existe este número en la vista, saltamos

                const nombre = inputNombre.trim();
                const pagado = formData.get(`pago_${i}`) !== null; // true si está marcado

                if (nombre !== '') {
                    // CASO 1: El boleto está ocupado (tiene un nombre)
                    datosRifa.push({
                        id_rifa: i,
                        nombre: nombre,
                        estado: pagado ? 'pagado' : 'pendiente'
                    });
                } else {
                    // CASO 2: El nombre se borró. Lo enviamos vacío para que el Backend LIMPIE la base de datos
                    datosRifa.push({
                        id_rifa: i,
                        nombre: '',
                        estado: 'disponible'
                    });
                }
            }

            // Validamos si hay algo que procesar 
            if (datosRifa.length === 0) {
                alert('No hay modificaciones para guardar.');
                return;
            }

            try {
                const response = await fetch('/rifas/guardar', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        boletos: datosRifa
                    })
                });

                const resultado = await response.json();

                if (resultado.success) {
                    alert('¡Rifa actualizada correctamente!');
                    window.location.reload(); // Recarga y pintará la card blanca de nuevo
                } else {
                    alert('Hubo un error al guardar los datos.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error de conexión con el servidor.');
            }
        });
    </script>
</body>

</html>