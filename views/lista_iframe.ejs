<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
            padding: 15px;
            font-size: 0.9rem;
        }
        
        .status-badge {
            font-size: 0.75rem;
            padding: 4px 8px;
            border-radius: 12px;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Solicitudes del Celular: <strong><%= celular %></strong></h5>
            <span class="badge bg-primary"><%= solicitudes.length %> registros</span>
        </div>
        <% console.log('solicitudes: front', solicitudes) %>


            <% if (solicitudes.length > 0) { %>
                <% console.log('solicitudes: front entro a la condicion', solicitudes) %>
                    <div class="table-responsive">
                        <table class="table table-hover bg-white shadow-sm">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Estado</th>
                                    <th>Monto Cuota</th>
                                    <th>Fecha Pago</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% solicitudes.forEach(sol => { %>
                                    <tr>
                                        <td>
                                            <%= sol.idSolicitud %>
                                        </td>
                                        <td>
                                            <% 
                                        let badgeClass = 'bg-secondary';
                                        if(sol.estadoSolicitud === 'Aprobado') badgeClass = 'bg-success';
                                        if(sol.estadoSolicitud === 'En Legal') badgeClass = 'bg-warning text-dark';
                                    %>
                                                <span class="badge status-badge <%= badgeClass %>">
                                        <%= sol.estadoSolicitud %>
                                    </span>
                                        </td>
                                        <td>
                                            <% if(sol.montoCuota) { %>
                                                <%= sol.montoCuota=Intl.NumberFormat('en-EN', { style: 'currency' , currency: 'USD' }).format(sol.montoCuota) %>
                                                    <% } else { %>
                                                        N/A
                                                        <% } %>
                                        </td>
                                        <td>
                                            <% if(sol.fechaPago) { %>
                                                <%= sol.fechaPago.toLocaleString('es-ES', { timeZone: "America/Santo_Domingo" },)  %>
                                                    <% } else { %>
                                                        Sin fecha
                                                        <% } %>
                                        </td>
                                        <td>
                                            <a href="/solicitudes/editar-solicitud/<%= sol.idSolicitud %>" class="btn btn-sm btn-outline-primary" target="_parent">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="alert alert-info mt-4">
                            No se encontraron solicitudes registradas para este número de celular
                            <%= celular %>.
                        </div>
                        <% } %>
    </div>
</body>

</html>