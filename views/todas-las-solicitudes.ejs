    <div class="container-fluid p-4 mt-5">
        <h3 style="color: #2f6eaa;" class=""><strong>REPORTES</strong> TOTAL DE SOLICITUDES</h3>
        <div style="border-radius: 50px; box-shadow:  20px 20px 60px #bebebe, -20px -20px 60px #ffffff;" class="container-fluid p-4">
            <div class="container-table table-responsive">
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label>Filtrar por Ruta:</label>
                        <select id="filtroRuta" class="form-control">
                             <option value="">Todas las rutas</option>
                             <option value="Sin Ruta Establecida">Sin Ruta Establecida</option>
                             <% if (arrayRutas.length > 0) { %>
                                 <% arrayRutas.forEach(ruta => { %>
                                     <option value="<%= ruta.nombreRuta %>"><%= ruta.nombreRuta %></option>
                                 <% }) %>
                             <% } %>
                            </select>
                    </div>
                    <div class="col-md-2">
                        <label>Filtrar por Clasificación:</label>
                        <select id="filtroClasificacion" class="form-control">
                                <option value="">Todas las clasificaciones</option>
                                <option value="Sin Clasificacion">Sin Clasificacion</option>
                                       <% if (config.clasificacionCliente) { %>
                                         <% config.clasificacionCliente.forEach(clasificacionCliente=> { %>
                                        <option value="<%= clasificacionCliente %>">
                                             <%= clasificacionCliente %>
                                        </option>
                                        <% }) %>
                                         <% } %>

                            </select>
                    </div>
                    <div class="col-md-2">
                        <label>Filtrar por tipo:</label>
                        <select id="filtroTipo" class="form-control">
                                <option value="">Todos los Tipos</option>
                                <option value="Personal">Personal</option>
                                <option value="Comercial">Comercial</option>
                            </select>
                    </div>
                    <div class="col-md-2">
                        <label>Filtrar por estado:</label>
                        <select id="filtroEstado" class="form-control">
                                <option value="">Todos los Estados</option>
                                <% if (config.estadoSolicitud.length> 0) { %>
                                <% config.estadoSolicitud.forEach(estadoSolicitud=> { %>
                                 <option value="<%= estadoSolicitud %>"><%= estadoSolicitud %></option>
                                 <% }) %>
                                 <% } %>
                            </select>
                    </div>
                    <div class="col-md-2">
                        <label>Filtrar por frecuencia de pagos:</label>
                        <select id="filtroFrecuencia" class="form-control">
                                <option value="">Todas las frecuencias</option>
                                <% if (config.frecuencia_Pagos) { %>
                                <% config.frecuencia_Pagos.forEach(frecuencia => { %>
                                 <option value="<%= frecuencia %>"><%= frecuencia %></option>
                                 <% }) %>
                                 <% } %>
                            </select>
                    </div>
                    <div class="col-md-2">
                        <div class="d-flex mb-3">
                            <div class="me-2">
                                <label>Desde:</label>
                                <input style="width: auto;" type="date" id="min" class="form-control">
                            </div>
                            <div class="">
                                <label>Hasta:</label>
                                <input style="width: auto;" type="date" id="max" class="form-control">
                            </div>
                        </div>
                    </div>
                </div>
                <table id="datatable" class="display responsive nowrap" style="width:100%">
                    <!-- <table id="datatable" class="display table table-sm table-hover  " style="width: 100%;"> -->
                    <thead class="thead-ligth">
                        <tr>

                            <th scope="col">ID Solicitud</th>
                            <th scope="col">Nombre</th>
                            <th scope="col">Apellido</th>
                            <th scope="col">Cedula</th>
                            <th class="p-0">Celular</th>
                            <th class="p-0">Cliente id</th>
                            <th scope="col">Email</th>
                            <th scope="col">Fecha Solicitud</th>
                            <th scope="col">Monto Solicitud</th>
                            <th scope="col">Saldo Final</th>
                            <th scope="col">Tipo de Prestamo</th>
                            <th scope="col">Firma</th>
                            <th scope="col">Estado Solicitud</th>
                            <th scope="col">Clasificacion</th>
                            <th class="d-none" scope="col">Ruta</th>
                            <th class="d-none" scope="col">Frecuencia de Pagos</th>
                            <th scope="col">Ver Solicitud</th>

                        </tr>
                    </thead>
                    <tbody>

                        <% if (arrayTotalSolicitudes.length > 0) { %>
                            <% arrayTotalSolicitudes.forEach(solicitud=> { %>

                                <tr>

                                    <td>
                                        <%= solicitud.idSolicitud %>
                                    </td>
                                    <td>
                                        <%= solicitud.nombre %>
                                    </td>
                                    <td>
                                        <%= solicitud.apellido %>
                                    </td>
                                    <td>
                                        <%= solicitud.cedula %>
                                    </td>
                                    <td>
                                        <%= solicitud.celular %>
                                    </td>
                                    <td>
                                        <% if(solicitud.cliente_id_validacion) { %>
                                            <%= solicitud.cliente_id_validacion %>
                                                <% }else { %>
                                                    <span style="color: red;">Solicitud sin Cliente</span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= solicitud.email %>
                                    </td>

                                    <td>
                                        <%= solicitud.fechaSolicitud.toLocaleString('es-US', { timeZone: "America/Santo_Domingo"}) %>
                                    </td>
                                    <td>
                                        <%= solicitud.montoSolicitado=Intl.NumberFormat('en-EN', { style: 'currency' , currency: 'USD' }).format(solicitud.montoSolicitado) %>
                                    </td>
                                    <td>
                                        <% if(solicitud.saldoFinal){ %>
                                            <span style="color: green;">
                                                <%= solicitud.saldoFinal=Intl.NumberFormat('en-EN', { style: 'currency' , currency: 'USD' }).format(solicitud.saldoFinal) %>
                                            </span>
                                            <% }else if(solicitud.estadoSolicitud == 'Declinada'){ %>
                                                <span style="color: rgb(148, 3, 3);">No Aprobado</span>
                                                <% }else { %>
                                                    <span style="color: rgb(200, 130, 0);">Pendiente</span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= solicitud.tipoPrestamo %>
                                    </td>
                                    <td>
                                        <%= solicitud.firmaContrato %>
                                    </td>
                                    <td>
                                        <%= solicitud.estadoSolicitud %>
                                    </td>
                                    <td>
                                        <% if (solicitud.clasificacionCliente == 'Sin Clasificacion') { %>
                                            <span style="background-color: #ffffff; color: gray; border-radius: 5px; border: 1px solid gray; padding: 2px 5px;"><%= solicitud.clasificacionCliente %></span>
                                            <% } else if (solicitud.clasificacionCliente == 'A-Premium') { %>
                                                <span style="background-color: #ffffff; color: #2563eb; border-radius: 5px; border: 1px solid #2563eb; padding: 2px 5px;"><%= solicitud.clasificacionCliente %></span>
                                                <% } else if (solicitud.clasificacionCliente == 'B-Regular') { %>
                                                    <span style="background-color: #ffffff; color: #60a5fa; border-radius: 5px; border: 1px solid #60a5fa; padding: 2px 5px;"><%= solicitud.clasificacionCliente %></span>
                                                    <% } else if (solicitud.clasificacionCliente == 'C-Riesgo') { %>
                                                        <span style="background-color: #ffffff; color: orange; border-radius: 5px; border: 1px solid orange; padding: 2px 5px;"><%= solicitud.clasificacionCliente %></span>
                                                        <% } else if (solicitud.clasificacionCliente == 'D-Desestimado') { %>
                                                            <span style="background-color: #ffffff; color: darkred; border-radius: 5px; border: 1px solid darkred; padding: 2px 5px;"><%= solicitud.clasificacionCliente %></span>
                                                            <% } else if (solicitud.clasificacionCliente == 'E-Penalizado') { %>
                                                                <span style="background-color: #ffffff; color: black; border-radius: 5px; border: 1px solid black; padding: 2px 5px;"><%= solicitud.clasificacionCliente %></span>
                                                                <% } %>
                                    </td>
                                    <td class="d-none">
                                        <%= solicitud.ruta %>
                                    </td>
                                    <td class="d-none">
                                        <%= solicitud.frecuenciaPagos %>
                                    </td>
                                    <td class="w-0 "><a href="/solicitudes/editar-solicitud/<%= solicitud.idSolicitud %>" class="btn " title="Editar Solicitud"><i class="bi bi-pencil-square "></i></a>

                                    </td>
                                </tr>

                                <% }) %>
                                    <% } %>

                    </tbody>
                    <!-- <button id="excel">descargar</button> -->
                </table>
            </div>
        </div>
    </div>


    <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
    <a href="/panel-administracion" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
    </div>


    <script>
        $(document).ready(function() {
            $('#datatable').DataTable({
                order: [
                    [0, 'desc']
                ],

                dom: 'Blfrtip',
                buttons: [{
                        extend: 'excel',
                        text: 'Exportar a Excel',
                    }, {
                        extend: 'pdfHtml5',
                        orientation: 'landscape',
                        pageSize: 'LEGAL',
                        text: 'Exportar a PDF',
                    }

                ],
                language: {
                    "decimal": "",
                    "emptyTable": "No hay información",
                    "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                    "infoEmpty": "Mostrando 0 to 0 of 0 Entradas",
                    "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                    "infoPostFix": "",
                    "thousands": ",",
                    "lengthMenu": "Mostrar _MENU_ Entradas",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "search": "Buscar:",
                    "zeroRecords": "Sin resultados encontrados",
                    "paginate": {
                        "first": "Primero",
                        "last": "Ultimo",
                        "next": "Siguiente",
                        "previous": "Anterior"
                    }
                }
            });

            $('#filtroRuta').on('change', function() {
                // Obtenemos la instancia de la tabla
                var table = $('#datatable').DataTable();
                var val = $(this).val();

                if (val === "") {
                    // Si selecciona "Todas", limpiamos el filtro de esa columna
                    table.column(14).search('').draw();
                } else {
                    // Usamos una búsqueda simple (sin escapeRegex estricto) 
                    // para que ignore los iconos o etiquetas HTML que tengas en la celda
                    table.column(14).search(val).draw();
                }
            });

            $('#filtroClasificacion').on('change', function() {
                // Obtenemos la instancia de la tabla
                var table = $('#datatable').DataTable();
                var val = $(this).val();

                if (val === "") {
                    // Si selecciona "Todas", limpiamos el filtro de esa columna
                    table.column(13).search('').draw();
                } else {
                    // Usamos una búsqueda simple (sin escapeRegex estricto) 
                    // para que ignore los iconos o etiquetas HTML que tengas en la celda
                    table.column(13).search(val).draw();
                }
            });

            $('#filtroTipo').on('change', function() {
                // Obtenemos la instancia de la tabla
                var table = $('#datatable').DataTable();
                var val = $(this).val();

                if (val === "") {
                    // Si selecciona "Todas", limpiamos el filtro de esa columna
                    table.column(10).search('').draw();
                } else {
                    // Usamos una búsqueda simple (sin escapeRegex estricto) 
                    // para que ignore los iconos o etiquetas HTML que tengas en la celda
                    table.column(10).search(val).draw();
                }
            });
            $('#filtroEstado').on('change', function() {
                // Obtenemos la instancia de la tabla
                var table = $('#datatable').DataTable();
                var val = $(this).val();

                if (val === "") {
                    // Si selecciona "Todas", limpiamos el filtro de esa columna
                    table.column(12).search('').draw();
                } else {
                    // Usamos una búsqueda simple (sin escapeRegex estricto) 
                    // para que ignore los iconos o etiquetas HTML que tengas en la celda
                    table.column(12).search(val).draw();
                }
            });
            $('#filtroFrecuencia').on('change', function() {
                // Obtenemos la instancia de la tabla
                var table = $('#datatable').DataTable();
                var val = $(this).val();

                if (val === "") {
                    // Si selecciona "Todas", limpiamos el filtro de esa columna
                    table.column(15).search('').draw();
                } else {
                    // Usamos una búsqueda simple (sin escapeRegex estricto) 
                    // para que ignore los iconos o etiquetas HTML que tengas en la celda
                    table.column(15).search(val).draw();
                }
            });

            // 1. Definimos la función de filtrado personalizada
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var min = $('#min').val(); // Formato: YYYY-MM-DD
                    var max = $('#max').val(); // Formato: YYYY-MM-DD

                    // 1. Obtenemos el texto de la columna 7
                    var rawData = data[7] || "";
                    if (rawData === "") return true;

                    // 2. LIMPIEZA: Extraemos solo la parte de la fecha (lo que esté antes de la coma o el espacio)
                    // Si sale "2022, 12:48:07 p. m.-9-6", necesitamos extraer los números.
                    // Lo más seguro es usar una expresión regular para sacar día, mes y año.
                    var dateMatches = rawData.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);

                    if (!dateMatches) {
                        // Intento alternativo si el formato viene separado por espacios o comas
                        // Esto limpia casos raros de toLocaleString()
                        var cleanDate = rawData.split(',')[0].trim();
                        dateMatches = cleanDate.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
                    }

                    if (dateMatches) {
                        var day = dateMatches[1].padStart(2, '0');
                        var month = dateMatches[2].padStart(2, '0');
                        var year = dateMatches[3];

                        // 3. Formateamos a YYYY-MM-DD para comparar
                        var dateComparable = year + '-' + month + '-' + day;

                        // 4. Comparación lógica
                        if (
                            (min === "" && max === "") ||
                            (min === "" && dateComparable <= max) ||
                            (min <= dateComparable && max === "") ||
                            (min <= dateComparable && dateComparable <= max)
                        ) {
                            return true;
                        }
                    }

                    return false;
                }
            );

            // 2. Eventos para redibujar la tabla al cambiar las fechas
            $(document).ready(function() {
                // Asegúrate de que esta variable 'table' coincida con la inicialización de tu DataTable
                var table = $('#datatable').DataTable();

                $('#min, #max').on('change', function() {
                    table.draw();
                });
            });
        });
    </script>

