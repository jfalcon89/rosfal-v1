    <% 
    // 1. Monto Promedio Solicitado
    let sumaMontos = 0;
    arrayTotalSolicitudes.forEach(s => {
        // Limpiamos el string por si tiene comas o símbolos y convertimos a número
        let monto = parseFloat(s.montoSolicitado) || 0;
        sumaMontos += monto;
    });
    let montoPromedio = arrayTotalSolicitudes.length > 0 ? (sumaMontos / arrayTotalSolicitudes.length) : 0;

    // 2. Frecuencia de Pagos (Segmentación)
    const frecuencias = {
        diarios: arrayTotalSolicitudes.filter(s => s.frecuenciaPagos === 'pagos diarios').length,
        semanales: arrayTotalSolicitudes.filter(s => s.frecuenciaPagos === 'pagos semanales').length,
        quincenales: arrayTotalSolicitudes.filter(s => s.frecuenciaPagos === 'pagos quincenales').length,
        mensuales: arrayTotalSolicitudes.filter(s => s.frecuenciaPagos === 'pagos mensuales').length
    };
    // 4. Clasificacion de clientes
    const clasificacion = {
        Sin_Clasificacion: arrayTotalSolicitudes.filter(s => 
        !s.clasificacionCliente || 
        s.clasificacionCliente === '' || 
        s.clasificacionCliente.trim() === 'Sin Clasificacion'
        ).length,
        A_Primium: arrayTotalSolicitudes.filter(s => s.clasificacionCliente === 'A-Premium').length,
        B_Regular: arrayTotalSolicitudes.filter(s => s.clasificacionCliente === 'B-Regular').length,
        C_Riesgo: arrayTotalSolicitudes.filter(s => s.clasificacionCliente === 'C-Riesgo').length,
        D_Desestimado: arrayTotalSolicitudes.filter(s => s.clasificacionCliente === 'D-Desestimado').length,
        E_Penalizado: arrayTotalSolicitudes.filter(s => s.clasificacionCliente === 'E-Penalizado').length
    };

    

    // 3. Tipo de Préstamo
    const tiposPrestamo = {
        personal: arrayTotalSolicitudes.filter(s => s.tipoPrestamo === 'Personal').length,
        comercial: arrayTotalSolicitudes.filter(s => s.tipoPrestamo === 'Comercial').length
    };

    // 4. Solicitudes por Rutas (Conteo dinámico)
    const solicitudesPorRuta = {};
    arrayTotalSolicitudes.forEach(s => {
        const nombreRuta = s.ruta || 'Sin Ruta';
        solicitudesPorRuta[nombreRuta] = (solicitudesPorRuta[nombreRuta] || 0) + 1;
    });
    %>

        <% 
    // 1. Función para convertir cualquier formato de fecha de la DB a objeto JS
    const parsearFecha = (f) => {
        if (!f) return new Date(0); 
        // Si ya es un objeto Date (lo hace mysql2/sequelize), lo usa. 
        // Si es String "2025-09-21 21:13:26", aplica el replace para hacerlo ISO.
        return f instanceof Date ? f : new Date(f.toString().replace(' ', 'T'));
    };

    // 2. Definir el rango de la semana actual (Lunes 00:00:00 a Domingo 23:59:59)
    const hoy = new Date();
    const diaDeSemana = hoy.getDay(); // 0 es Domingo, 1 es Lunes...
    
    // Calcular Lunes: Si hoy es Domingo (0), restamos 6 días. Si no, restamos (día - 1).
    const fechaLunes = new Date(new Date().setDate(hoy.getDate() - (diaDeSemana === 0 ? 6 : diaDeSemana - 1)));
    fechaLunes.setHours(0, 0, 0, 0);

    const fechaDomingo = new Date(fechaLunes);
    fechaDomingo.setDate(fechaLunes.getDate() + 6);
    fechaDomingo.setHours(23, 59, 59, 999);

    // 3. Filtrar el arreglo de solicitudes
    const solicitudesEstaSemana = arrayTotalSolicitudes.filter(s => {
        const f = parsearFecha(s.fechaSolicitud);
        return f >= fechaLunes && f <= fechaDomingo;
    });

    // 4. Variables de resultado para el HTML
    const totalSemana = solicitudesEstaSemana.length;
    const totalGeneral = arrayTotalSolicitudes.length;
    const porcentajeSemana = totalGeneral > 0 ? ((totalSemana / totalGeneral) * 100).toFixed(1) : 0;

%>

            <% 
    // 1. Contamos el total de solicitudes general
    const totalSolicitudesRegistradas = arrayTotalSolicitudes.length;

    // 2. Filtramos solo las que tienen estado 'Declinada'
    // Usamos .toLowerCase() y .trim() por seguridad si vienen con espacios o variaciones
    const solicitudesDeclinadas = arrayTotalSolicitudes.filter(s => 
        s.estadoSolicitud && s.estadoSolicitud.trim().toLowerCase() === 'declinada'
    ).length;

    // 3. Calculamos la tasa de insatisfacción (Porcentaje de Declinadas)
    // Fórmula: (Declinadas / Total) * 100
    const tasaInsatisfaccion = totalSolicitudesRegistradas > 0 
        ? ((solicitudesDeclinadas / totalSolicitudesRegistradas) * 100).toFixed(1) 
        : 0;

    // 4. Extra: Tasa de Aprobación (Opcional para contraste)
    const tasaAprobacion = (100 - tasaInsatisfaccion).toFixed(1);
%>

                <% 
    // 1. Definimos los estados que queremos sumar
    const estadosValidos = ['Aprobada', 'En Legal'];

    // 2. Filtramos y sumamos el monto de las solicitudes que coincidan
    const montoTotalActivo = arrayTotalSolicitudes.reduce((acumulador, s) => {
        // Normalizamos el estado para evitar errores de mayúsculas o espacios
        const estado = s.estadoSolicitud ? s.estadoSolicitud.trim() : '';
        
        if (estadosValidos.includes(estado)) {
            // Limpiamos el string (quitamos RD$, comas, etc.) y convertimos a número
            const montoLimpio = parseFloat(s.montoSolicitado.replace(/[^0-9.]/g, '')) || 0;
            return acumulador + montoLimpio;
        }
        return acumulador;
    }, 0);


    // 3. Contar cuántas solicitudes representan ese monto
    const cantidadSolicitudesActivas = arrayTotalSolicitudes.filter(s => 
        estadosValidos.includes(s.estadoSolicitud ? s.estadoSolicitud.trim() : '')
    ).length;
%>

                    <% 
    // 1. Estados que definen cartera activa o en recuperación
    const estadosCartera = ['Aprobada', 'En Legal'];

    // 2. Cálculo del Saldo Pendiente Total
    const saldoTotalPendiente = arrayTotalSolicitudes.reduce((total, s) => {
        const estado = s.estadoSolicitud ? s.estadoSolicitud.trim() : '';
        
        if (estadosCartera.includes(estado)) {
            // Convertimos a número: eliminamos cualquier cosa que no sea número o punto
            // s.saldoFinal suele ser varchar(10) según tu estructura
            const valorSaldo = parseFloat(String(s.saldoFinal).replace(/[^0-9.]/g, '')) || 0;
            return total + valorSaldo;
        }
        return total;
    }, 0);

    // 3. Conteo de préstamos con saldo pendiente
    const prestamosConSaldo = arrayTotalSolicitudes.filter(s => {
        const estado = s.estadoSolicitud ? s.estadoSolicitud.trim() : '';
        const saldo = parseFloat(String(s.saldoFinal).replace(/[^0-9.]/g, '')) || 0;
        return estadosCartera.includes(estado) && saldo > 0;
    }).length;
%>

                        <% 
    // 1. Filtrar solo las solicitudes con estado 'Declinada'
    const solicitudesRechazadas = arrayTotalSolicitudes.filter(s => 
        s.estadoSolicitud && s.estadoSolicitud.trim().toLowerCase() === 'declinada'
    );

    // 2. Sumar el monto solicitado de estas solicitudes
    const montoTotalDeclinado = solicitudesRechazadas.reduce((total, s) => {
        // Limpiamos el varchar(10) para convertirlo a número sumable
        const monto = parseFloat(String(s.montoSolicitado).replace(/[^0-9.]/g, '')) || 0;
        return total + monto;
    }, 0);

    // 3. Cantidad de solicitudes declinadas
    const cantidadDeclinadas = solicitudesRechazadas.length;
%>
