                                        </div>
                                        <div class="col-12 col-lg-6">
                                            <div class="card border-0 shadow-sm p-4 h-100">
                                                <h3 class="h6 fw-bold text-secondary mb-4">Encuestas por Encuestador</h3>
                                                <div style="position: relative; height:300px;">
                                                    <canvas id="encuestasStaff"></canvas>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                            </main>

                            <div class="container-fluid p-4 mt-5">
                                <h3 style="color: #2f6eaa;" class="">NUEVAS</h3>
                                <div style="border-radius: 50px; box-shadow:  20px 20px 60px #bebebe, -20px -20px 60px #ffffff;" class="container-fluid p-4">
                                    <div class="container-table table-responsive">
                                        <table id="datatable" class="display responsive nowrap compact" style="width:100%">
                                            <!-- <table id="datatable" class="display table table-sm table-hover  " style="width: 100%;"> -->
                                            <thead class="thead-ligth">
                                                <tr>
                                                    <th class="p-0">ID Solicitud</th>
                                                    <th class="p-0">Nombre</th>
                                                    <th class="p-0">Apellido</th>
                                                    <th class="p-0">Cedula</th>
                                                    <th class="p-0">Celular</th>
                                                    <th class="p-0">Cliente id</th>
                                                    <th scope="col">Email</th>
                                                    <th class="p-0">Fecha Solicitud</th>
                                                    <th class="p-0">Monto Solicitud</th>
                                                    <th class="p-0">Tipo de Prestamo</th>
                                                    <th class="p-0">Estado Solicitud</th>
                                                    <th class="p-0">Clasificacion</th>
                                                    <th class="p-0">Ver Solicitud</th>
                                                </tr>
                                            </thead>
                                            <tbody>

                                                <% if (arraySolicitudesNuevas.length > 0) { %>
                                                    <% arraySolicitudesNuevas.forEach(solicitud=> { %>

                                                        <tr>

                                                            <td>
                                                                <%= solicitud.idSolicitud %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.nombre %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.apellido %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.cedula %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.celular %>
                                                            </td>
                                                            <td>
                                                                <% if(solicitud.cliente_id_validacion) { %>
                                                                    <%= solicitud.cliente_id_validacion %>
                                                                        <% }else { %>
                                                                            <span style="color: red;">Solicitud sin Cliente</span>
                                                                            <% } %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.email %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.fechaSolicitud.toLocaleString('es-US', { timeZone: "America/Santo_Domingo"}) %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.montoSolicitado %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.tipoPrestamo %>
                                                            </td>
                                                            <td>
                                                                <%= solicitud.estadoSolicitud %>
                                                            </td>
                                                            <td>
                                                                <% if (solicitud.clasificacionCliente == 'Sin Clasificacion') { %>
                                                                    <p style="background-color: gray; color: white;">
                                                                        <%= solicitud.clasificacionCliente %>
                                                                    </p>
                                                                    <% } else if (solicitud.clasificacionCliente == 'A-Premium') { %>
                                                                        <p style="background-color: green; color: white;">
                                                                            <%= solicitud.clasificacionCliente %>
                                                                        </p>
                                                                        <% } else if (solicitud.clasificacionCliente == 'B-Regular') { %>
                                                                            <p style="background-color: yellow; color: black;">
                                                                                <%= solicitud.clasificacionCliente %>
                                                                            </p>
                                                                            <% } else if (solicitud.clasificacionCliente == 'C-Riesgo') { %>
                                                                                <p style="background-color: orange; color: black;">
                                                                                    <%= solicitud.clasificacionCliente %>
                                                                                </p>
                                                                                <% } else if (solicitud.clasificacionCliente == 'D-Desestimado') { %>
                                                                                    <p style="background-color: darkred; color: white;">
                                                                                        <%= solicitud.clasificacionCliente %>
                                                                                    </p>
                                                                                    <% } else if (solicitud.clasificacionCliente == 'E-Penalizado') { %>
                                                                                        <p style="background-color: rgb(0, 0, 0); color: white;">
                                                                                            <%= solicitud.clasificacionCliente %>
                                                                                        </p>
                                                                                        <% } %>
                                                            </td>
                                                            <td class="w-0 "><a href="/solicitudes/editar-solicitud/<%= solicitud.idSolicitud %>" class="btn " title="Editar Solicitud"><i class="bi bi-pencil-square "></i></a>

                                                            </td>
                                                        </tr>

                                                        <% }) %>
                                                            <% } %>

                                            </tbody>
                                            <!-- <button id="excel">descargar</button> -->
                                        </table>
                                    </div>
                                </div>
                            </div>


                            <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
                            <a href="/panel-administracion" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
                            </div>


                            <script>
                                document.addEventListener('DOMContentLoaded', function() {
                                    // Configuración del Gráfico de Prioridades
                                    const ctxPriority = document.getElementById('priorityChart');
                                    if (ctxPriority) {
                                        new Chart(ctxPriority, {
                                            type: 'bar',
                                            data: {
                                                labels: ['Pagos Diarios', 'Pagos Semanales', 'Pagos Quincenales', 'Pagos Mensuales'],
                                                datasets: [{
                                                    label: 'Número de Negocios',
                                                    data: [`<%= frecuencias.diarios %>`, `<%= frecuencias.semanales %>`, `<%= frecuencias.quincenales %>`, `<%= frecuencias.mensuales %>`],
                                                    backgroundColor: ['#60a5fa', '#64748b', '#cbd5e1', '#2B7FFF'],
                                                    borderRadius: 8
                                                }]
                                            },
                                            options: {
                                                responsive: true,
                                                maintainAspectRatio: false,
                                                plugins: {
                                                    legend: {
                                                        display: false
                                                    }
                                                },
                                                scales: {
                                                    y: {
                                                        beginAtZero: true
                                                    }
                                                }
                                            }
                                        });
                                    }

                                    // Configuración del Gráfico de Tipos de Negocio
                                    const ctxBusiness = document.getElementById('businessTypeChart');
                                    if (ctxBusiness) {
                                        new Chart(ctxBusiness, {
                                            type: 'doughnut',
                                            data: {
                                                labels: ['Personal', 'Comercial'],
                                                datasets: [{
                                                    data: [`<%= tiposPrestamo.personal %>`, `<%= tiposPrestamo.comercial %>`],
                                                    backgroundColor: ['#60a5fa', '#cbd5e1'],
                                                    borderWidth: 0
                                                }]
                                            },
                                            options: {
                                                responsive: true,
                                                maintainAspectRatio: false,
                                                plugins: {
                                                    legend: {
                                                        position: 'left',
                                                        labels: {
                                                            padding: 20
                                                        }
                                                    }
                                                }
                                            }
                                        });
                                    }



                                    // Configuración del Gráfico clasificacion por solicitudes
                                    const ctxClasificacion = document.getElementById('clasificacionSolicitudes');

                                    if (ctxClasificacion) {
                                        new Chart(ctxClasificacion, {
                                            type: 'doughnut',
                                            data: {
                                                // El orden de labels debe coincidir con el orden de data abajo
                                                labels: ['A-Premium', 'B-Regular', 'C-Riesgo', 'D-Desestimado', 'Sin Clasificación', 'E-Penalizado'],
                                                datasets: [{
                                                    data: [
                                                        <%= clasificacion.A_Primium %>,
                                                        <%= clasificacion.B_Regular %>,
                                                        <%= clasificacion.C_Riesgo %>,
                                                        <%= clasificacion.D_Desestimado %>,
                                                        <%= clasificacion.Sin_Clasificacion %>,
                                                        <%= clasificacion.E_Penalizado %>
                                                    ],
                                                    // Añadí un color extra porque tienes 5 categorías y solo había 4 colores
                                                    backgroundColor: ['#2563eb', '#60a5fa', '#f59e0b', '#ef4444', '#94a3b8', '#0C0A09'],
                                                    borderWidth: 2,
                                                    borderColor: '#ffffff'
                                                }]
                                            },
                                            options: {
                                                responsive: true,
                                                maintainAspectRatio: false,
                                                cutout: '65%',
                                                plugins: {
                                                    legend: {
                                                        position: 'left',
                                                        labels: {
                                                            padding: 15,
                                                            usePointStyle: true,
                                                            font: {
                                                                family: "'Inter', sans-serif",
                                                                size: 12
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        });
                                    }

                                    // Configuración del Gráfico de solicitudes por Rutas (Préstamos)
                                    const ctxRutasPrestamos = document.getElementById('encuestasRutas');

                                    if (ctxRutasPrestamos) {
                                        // 1. Extraemos los datos de la variable que procesamos en EJS
                                        // etiquetasRutasPrestamos será algo como ["Ruta 1", "Ruta 2"]
                                        // valoresRutasPrestamos será algo como [15, 8]
                                        const etiquetasRutasPrestamos = <%- JSON.stringify(Object.keys(solicitudesPorRuta)) %>;
                                        const valoresRutasPrestamos = <%- JSON.stringify(Object.values(solicitudesPorRuta)) %>;

                                        new Chart(ctxRutasPrestamos, {
                                            type: 'doughnut',
                                            data: {
                                                labels: etiquetasRutasPrestamos,
                                                datasets: [{
                                                    data: valoresRutasPrestamos,
                                                    backgroundColor: [
                                                        '#0f173q', // Slate 900
                                                        '#2563eb', // Blue 600
                                                        '#60a5fa', // Blue 400
                                                        '#94a3b8', // Slate 400
                                                        '#38bdf8', // Sky 400
                                                        '#1e293b', // Slate 800
                                                        '#475569', // Slate 600
                                                        '#cbd5e1' // Slate 200
                                                    ],
                                                    borderWidth: 2,
                                                    borderColor: '#ffffff' // Espacio blanco entre segmentos
                                                }]
                                            },
                                            options: {
                                                responsive: true,
                                                maintainAspectRatio: false,
                                                cutout: '70%', // Hace el agujero del centro más grande (estilo moderno)
                                                plugins: {
                                                    legend: {
                                                        position: 'left',
                                                        align: 'center',
                                                        labels: {
                                                            padding: 20,
                                                            usePointStyle: true, // Círculos en lugar de cuadrados
                                                            pointStyle: 'circle',
                                                            font: {
                                                                size: 13,
                                                                family: "'Inter', 'Segoe UI', sans-serif",
                                                                weight: '500'
                                                            },
                                                            color: '#475569'
                                                        }
                                                    },
                                                    tooltip: {
                                                        backgroundColor: '#1e293b',
                                                        padding: 12,
                                                        titleFont: {
                                                            size: 14
                                                        },
                                                        bodyFont: {
                                                            size: 13
                                                        },
                                                        displayColors: true
                                                    }
                                                },
                                                layout: {
                                                    padding: {
                                                        left: 20,
                                                        right: 20,
                                                        top: 10,
                                                        bottom: 10
                                                    }
                                                }
                                            }
                                        });
                                    }

                                    // Configuración del Gráfico de Rendimiento por Encuestador
                                    const ctxStaff = document.getElementById('encuestasStaff');

                                    if (ctxStaff) {
                                        new Chart(ctxStaff, {
                                            type: 'bar', // Cambiado a barras para mejor lectura de nombres
                                            data: {
                                                labels: <%- JSON.stringify(etiquetasEncuestadores) %>,
                                                datasets: [{
                                                    label: 'Encuestas Realizadas',
                                                    data: <%- JSON.stringify(valoresEncuestadores) %>,
                                                    backgroundColor: '#60a5fa', // Un azul sólido profesional
                                                    borderRadius: 5,
                                                    borderWidth: 0
                                                }]
                                            },
                                            options: {
                                                indexAxis: 'y', // Hace que las barras sean horizontales
                                                responsive: true,
                                                maintainAspectRatio: false,
                                                plugins: {
                                                    legend: {
                                                        display: false
                                                    } // Ocultamos la leyenda para ganar espacio
                                                },
                                                scales: {
                                                    x: {
                                                        beginAtZero: true,
                                                        grid: {
                                                            display: false
                                                        },
                                                        ticks: {
                                                            stepSize: 1
                                                        } // Solo números enteros
                                                    },
                                                    y: {
                                                        grid: {
                                                            display: false
                                                        }
                                                    }
                                                }
                                            }
                                        });
                                    }
                                });
                            </script>


                            <script>
                                $(document).ready(function() {
                                    $('#datatable').DataTable({
                                        order: [
                                            [0, 'desc']
                                        ],


                                        language: {
                                            "decimal": "",
                                            "emptyTable": "No hay información",
                                            "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                                            "infoEmpty": "Mostrando 0 to 0 of 0 Entradas",
                                            "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                                            "infoPostFix": "",
                                            "thousands": ",",
                                            "lengthMenu": "Mostrar _MENU_ Entradas",
                                            "loadingRecords": "Cargando...",
                                            "processing": "Procesando...",
                                            "search": "Buscar:",
                                            "zeroRecords": "Sin resultados encontrados",
                                            "paginate": {
                                                "first": "Primero",
                                                "last": "Ultimo",
                                                "next": "Siguiente",
                                                "previous": "Anterior"
                                            }
                                        }
                                    });

                                });
                            </script>



</body>

</html>