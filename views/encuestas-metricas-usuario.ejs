                                                            </td>
                                                            <td class="py-4 text-sm">
                                                                <%= encuesta.tipo_negocio %>
                                                            </td>
                                                            <td class="py-4 text-sm">
                                                                <%= encuesta.tipo_negocio_otro %>
                                                            </td>
                                                            <td class="py-4 text-sm">
                                                                <%= encuesta.ruta %>
                                                            </td>
                                                            <td class="py-4 text-sm">
