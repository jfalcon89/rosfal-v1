    <% 
    // 1. Función para convertir cualquier formato de fecha de la DB a objeto JS
    const parsearFecha = (f) => {
        if (!f) return new Date(0); 
        // Si ya es un objeto Date (lo hace mysql2/sequelize), lo usa. 
        // Si es String "2025-09-21 21:13:26", aplica el replace para hacerlo ISO.
        return f instanceof Date ? f : new Date(f.toString().replace(' ', 'T'));
    };

    // 2. Definir el rango de la semana actual (Lunes 00:00:00 a Domingo 23:59:59)
    const hoy = new Date();
    const diaDeSemana = hoy.getDay(); // 0 es Domingo, 1 es Lunes...
    
    // Calcular Lunes: Si hoy es Domingo (0), restamos 6 días. Si no, restamos (día - 1).
    const fechaLunes = new Date(new Date().setDate(hoy.getDate() - (diaDeSemana === 0 ? 6 : diaDeSemana - 1)));
    fechaLunes.setHours(0, 0, 0, 0);

    const fechaDomingo = new Date(fechaLunes);
    fechaDomingo.setDate(fechaLunes.getDate() + 6);
    fechaDomingo.setHours(23, 59, 59, 999);

    // 3. Filtrar el arreglo de solicitudes
    const solicitudesEstaSemana = arrayEncuestas.filter(s => {
        const f = parsearFecha(s.creado_el);
        return f >= fechaLunes && f <= fechaDomingo;
    });

    // 4. Variables de resultado para el HTML
    const totalSemana = solicitudesEstaSemana.length;
    const totalGeneral = arrayEncuestas.length;
    const porcentajeSemana = totalGeneral > 0 ? ((totalSemana / totalGeneral) * 100).toFixed(1) : 0;

