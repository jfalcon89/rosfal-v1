        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Configuración del Gráfico de Prioridades
                const ctxPriority = document.getElementById('priorityChart');
                if (ctxPriority) {
                    new Chart(ctxPriority, {
                        type: 'bar',
                        data: {
                            labels: ['Inventario', 'Equipos', 'Remodelación'],
                            datasets: [{
                                label: 'Número de Negocios',
                                data: [`<%= totalInventario %>`, `<%= totalEquipos %>`, `<%= totalRemodelacion %>`],
                                backgroundColor: ['#60a5fa', '#64748b', '#cbd5e1'],
                                borderRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true
                                }
                            }
                        }
                    });
                }

                // Configuración del Gráfico de Tipos de Negocio
                const ctxBusiness = document.getElementById('businessTypeChart');
                if (ctxBusiness) {
                    new Chart(ctxBusiness, {
                        type: 'doughnut',
                        data: {
                            labels: ['Colmados', 'Salones', 'Peluquerías', 'Otros'],
                            datasets: [{
                                data: [`<%= totalColmados %>`, `<%= totalSalones %>`, `<%= totalPeluquerias %>`, `<%= totalOtros %>`],
                                backgroundColor: ['#60a5fa', '#2563eb', '#64748b', '#e2e8f0'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'left',
                                    labels: {
                                        padding: 20
                                    }
                                }
                            }
                        }
                    });
                }

                // Configuración del Gráfico de Rutas Dinámico
                const ctxRutas = document.getElementById('encuestasRutas');

                if (ctxRutas) {
                    new Chart(ctxRutas, {
                        type: 'doughnut',
                        data: {
                            // Inyectamos las rutas dinámicas desde el servidor
                            labels: <%- JSON.stringify(etiquetasRutas) %>,
                            datasets: [{
                                data: <%- JSON.stringify(valoresRutas) %>,
                                backgroundColor: [
                                    // --- LA BASE ROSFAL (Azules) ---
                                    '#00BFFF',
                                    '#ADD8E6',
                                    '#B0C4DE',
                                    '#C0C0C0',
                                    '#2984D1',
                                    '#53EAFD',
                                    '#51A2FF',
                                    '#cbd5e1'
                                ],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    // CAMBIO AQUÍ: Posición a la izquierda
                                    position: 'left',
                                    align: 'center', // Centra la lista verticalmente respecto al gráfico
                                    labels: {
                                        padding: 15, // Espacio entre cada nombre de ruta
                                        usePointStyle: true, // Cambia el cuadrado por un círculo (se ve más moderno)
                                        font: {
                                            size: 12,
                                            family: "'Inter', sans-serif"
                                        }
                                    }
                                }
                            },
                            // Añadimos un poco de espacio extra a la izquierda para que no se pegue al borde
                            layout: {
                                padding: {
                                    left: 10
                                }
                            }
                        }
                    });
                }

                // Configuración del Gráfico de Rendimiento por Encuestador
                const ctxStaff = document.getElementById('encuestasStaff');

                if (ctxStaff) {
                    new Chart(ctxStaff, {
                        type: 'bar', // Cambiado a barras para mejor lectura de nombres
                        data: {
                            labels: <%- JSON.stringify(etiquetasEncuestadores) %>,
                            datasets: [{
                                label: 'Encuestas Realizadas',
                                data: <%- JSON.stringify(valoresEncuestadores) %>,
                                backgroundColor: '#60a5fa', // Un azul sólido profesional
                                borderRadius: 5,
                                borderWidth: 0
                            }]
                        },
                        options: {
                            indexAxis: 'y', // Hace que las barras sean horizontales
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false
                                } // Ocultamos la leyenda para ganar espacio
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    grid: {
                                        display: false
                                    },
                                    ticks: {
                                        stepSize: 1
                                    } // Solo números enteros
                                },
                                y: {
                                    grid: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
                }
            });
        </script>


        <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
        <a href="/encuesta" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
        </div>





</body>

</html>