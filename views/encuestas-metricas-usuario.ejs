        %>
                <% 
          // Conteo por Tipo de Negocio
          const totalColmados = arrayEncuestas.filter(e => e.tipo_negocio === 'Colmado').length;
          const totalSalones = arrayEncuestas.filter(e => e.tipo_negocio === 'Salón de Belleza').length;
          const totalPeluquerias = arrayEncuestas.filter(e => e.tipo_negocio === 'Peluquería').length;
          const totalOtros = arrayEncuestas.filter(e => e.tipo_negocio === 'Otro').length;
        %>
                    <% 
                    // Creamos un objeto vacío para acumular los conteos
                    const conteoRutas = {}; 

                    arrayEncuestas.forEach(encuesta => {
                        // Extraemos el nombre de la ruta de la encuesta actual
                        const nombreRuta = encuesta.ruta || 'Sin Ruta'; 
                        
                        // Si la ruta ya existe en el objeto, le sumamos 1. Si no, la iniciamos en 1.
                        if (conteoRutas[nombreRuta]) {
                        conteoRutas[nombreRuta]++;
                        } else {
                        conteoRutas[nombreRuta] = 1;
                        }
                    });

                    // Convertimos el objeto en dos arreglos que Chart.js pueda entender
                    const etiquetasRutas = Object.keys(conteoRutas); // Ejemplo: ['Ruta Norte', 'Ruta Sur']
                    const valoresRutas = Object.values(conteoRutas);  // Ejemplo: [10, 5]
                    %>

                        <% 
