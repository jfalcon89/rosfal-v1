                            // Extraemos el nombre del campo 'encuestador'
                            const nombrePersona = encuesta.encuestador || 'Sin Asignar'; 
                            
                            if (conteoEncuestadores[nombrePersona]) {
                            conteoEncuestadores[nombrePersona]++;
                            } else {
                            conteoEncuestadores[nombrePersona] = 1;
                            }
                        });

                        // 2. Preparamos las etiquetas y los valores para Chart.js
                        const etiquetasEncuestadores = Object.keys(conteoEncuestadores);
                        const valoresEncuestadores = Object.values(conteoEncuestadores);
