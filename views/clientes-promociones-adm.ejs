    <script>
        function actualizarProgreso(fechaInicioStr, fechaVencimientoStr, id) {
            const hoy = new Date();
            const inicio = new Date(fechaInicioStr);
            const vencimiento = new Date(fechaVencimientoStr);

            // Seleccionamos los elementos específicos de este registro usando el ID
            const fill = document.getElementById('progressFill' + id);
            const text = document.getElementById('daysLeft' + id);
            const range = document.getElementById('dateRange' + id);

            //modal
            const fillModal = document.getElementById('progressFillModal' + id);
            const textModal = document.getElementById('daysLeftModal' + id);
            const rangeModal = document.getElementById('dateRangeModal' + id);

            if (!fill || !text) return; // Seguridad

            if (hoy > vencimiento) {
                fill.style.width = "100%";
                fill.style.backgroundColor = "#e74c3c";
                text.innerText = "¡Plazo vencido!";
                fillModal.style.width = "100%";
                fillModal.style.backgroundColor = "#e74c3c";
                textModal.innerText = "¡Plazo vencido!";
                return;
            }



            if (vencimiento == "Invalid Date" || isNaN(vencimiento.getTime())) {
                fill.style.width = "100%";
                fill.style.backgroundColor = "#B3B3B3";
                text.innerText = "¡Plazo sin establecer!";
                fillModal.style.width = "100%";
                fillModal.style.backgroundColor = "#B3B3B3";
                textModal.innerText = "¡Plazo sin establecer!";
                return;
            }



            const tiempoTotal = vencimiento - inicio;
            const tiempoTranscurrido = hoy - inicio;

            let porcentaje = (tiempoTranscurrido / tiempoTotal) * 100;
            porcentaje = Math.min(Math.max(porcentaje, 0), 100);

            const milisegundosPorDia = 1000 * 60 * 60 * 24;
            const diasFaltantes = Math.ceil((vencimiento - hoy) / milisegundosPorDia);

            fill.style.width = porcentaje + "%";
            text.innerText = `Faltan ${diasFaltantes} días para el vencimiento`;
            if (range) range.innerText = `Fin: ${vencimiento.toLocaleDateString()}`;

            fillModal.style.width = porcentaje + "%";
            textModal.innerText = `Faltan ${diasFaltantes} días para el vencimiento`;
            if (rangeModal) rangeModal.innerText = `Fin: ${vencimiento.toLocaleDateString()}`;
        }
    </script>

