    </div>


    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Detectamos todos los botones que abren el modal de iframe
            const buttons = document.querySelectorAll('.open-modal-iframe');

            buttons.forEach(button => {
                button.addEventListener('click', function() {
                    const url = this.getAttribute('data-url');
                    const targetModal = this.getAttribute('data-bs-target');
                    const iframe = document.querySelector(targetModal + ' iframe');

                    // Si el iframe ya tiene la misma URL, no la recargamos
                    if (iframe && iframe.src !== window.location.origin + url) {
                        iframe.src = url;
                    }
                });
            });
        });
    </script>


