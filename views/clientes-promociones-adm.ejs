                                                                        const tiempoTotal = vencimiento - inicio;
                                                                        const tiempoTranscurrido = hoy - inicio;

                                                                        // Calcular porcentaje (Asegurándonos de que no sea menor a 0 ni mayor a 100)
                                                                        let porcentaje = (tiempoTranscurrido / tiempoTotal) * 100;
                                                                        porcentaje = Math.min(Math.max(porcentaje, 0), 100);

                                                                        // Calcular días restantes
                                                                        const milisegundosPorDia = 1000 * 60 * 60 * 24;
                                                                        const diasFaltantes = Math.ceil((vencimiento - hoy) / milisegundosPorDia);

                                                                        // Actualizar el DOM
                                                                        document.getElementById('progressFill').style.width = porcentaje + "%";
                                                                        document.getElementById('daysLeft').innerText = `Faltan ${diasFaltantes} días para el vencimiento`;
                                                                        document.getElementById('dateRange').innerText = `Inicio: ${inicio.toLocaleDateString()} - Fin: ${vencimiento.toLocaleDateString()}`;
                                                                    }

                                                                    // EJEMPLO: 
                                                                    // Fecha en que inició el proceso: 1 de Abril 2026
                                                                    // Fecha de vigencia final: 1 de Junio 2026
                                                                    actualizarProgreso("2026-04-01", "2026-06-01");
                                                                    console.log("Fecha de inicio: " + new Date("2026-04-01").toLocaleDateString());
                                                                    console.log("Fecha de vencimiento: " + new Date("2026-06-01").toLocaleDateString());
                                                                </script> -->

                                                                    <span class="text-danger">* La vigencia se toma en cuenta para el proceso de eliminación automática de promociones vencidas, si se deja vacía la promoción no se eliminará automáticamente al vencer su fecha.</span>
