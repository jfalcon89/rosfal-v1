<body style="background-color: white;">

    <nav class="flex items-center justify-between px-4 py-2 bg-gradient-to-r from-[#eaf6ff] to-[#a5d3ff] rounded-b-[15px] shadow-sm">
        <div class="flex items-center space-x-3">
            <img src="/img/LOGO-ROSFAL.png" alt="logo-rosfal" class="w-[80px]">
            <h5 class="text-gray-800 font-semibold text-lg uppercase tracking-wider">Encuestas</h5>
        </div>

        <button class="lg:hidden text-gray-600 focus:outline-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m4 6h16"></path>
        </svg>
    </button>

        <div class="hidden lg:flex items-center space-x-4">
            <div class="flex items-center bg-white/40 px-4 py-1 rounded-full border border-blue-200">
                <i class="bi bi-person-square text-[30px] text-blue-600 mr-3"></i>
                <% if (login) { %>
                    <div class="leading-tight">
                        <h4 class="text-sm font-bold text-gray-700 uppercase">
                            <%= name %>
                        </h4>
                        <h6 class="text-xs text-blue-800 font-medium">
                            <%= rol %>
                        </h6>
                    </div>
                    <% } %>
            </div>

            <button class="p-2 hover:bg-blue-100 rounded-full transition-colors" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas">
            <i class="bi bi-list text-2xl"></i>
        </button>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start !border-none !rounded-r-2xl shadow-2xl" tabindex="-1" id="navbarOffcanvas" aria-labelledby="navbarOffcanvasLabel">
        <div class="flex items-center justify-between p-4 border-b border-gray-100">
            <h5 class="text-blue-900 font-bold text-lg italic" id="navbarOffcanvasLabel">ROSFAL MENU</h5>
            <button type="button" class="text-gray-400 hover:text-black transition-colors" data-bs-dismiss="offcanvas">
            <i class="bi bi-x-lg text-xl"></i>
        </button>
        </div>

        <div class="p-4">
            <div class="flex items-center p-3 bg-gray-50 rounded-xl mb-6">
                <% if (login) { %>
                    <i class="bi bi-person-square text-[40px] text-gray-400 mr-4"></i>
                    <div>
                        <h4 class="text-gray-600 font-bold text-base leading-none mb-1">
                            <%= name %>
                        </h4>
                        <p class="text-xs text-gray-400 uppercase tracking-tighter">
                            <%= rol %>
                        </p>
                    </div>
                    <% } %>
            </div>

            <div class="space-y-2">
                <%- include('template/navbar-menu') %>
            </div>
        </div>
    </div>
    <div class=" p-2 d-lg-flex flex-sm-row mt-4 " style="background-color: #ececec;">
        <div class="container-fluid mt-3 mb-3 me-lg-3 d-flex holographic-card bg-white" style=" border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📊</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3 style="color: #2f6eaa;">
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo">
                        <a style="color: #2f6eaa;" class="text-decoration-none fs-5" href="/encuestas-metricas-usuario">
                            
                                 Metricas
                        
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid  mt-3 mb-3 me-lg-3 d-flex holographic-card" style=" background-color: #d4d4d4; border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📍</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3>
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/mapa-rutas-usuario">Mapas de Rutas</a></div>
                </div>
            </div>
        </div>

    </div>

    <div class="flex items-center justify-between mb-6 p-4 bg-white rounded-lg shadow">
        <div>
            <h1 class="text-xl font-bold text-slate-900">Rutas</h1>
            <select id="selectRuta" class="mt-2 p-2 border rounded border-slate-300 w-80 text-sm">
            <option value="">Seleccione una ruta...</option>
            <% if (arrayRutas.length > 0) { %>
                <% arrayRutas.forEach(ruta => { %>
                    <option value="<%= ruta.localizacion_map %>"><%= ruta.nombreRuta %></option>
                <% }) %>
            <% } %>
        </select>
        </div>
        <div class="flex gap-2">
            <button id="btnVerCards" class="bg-blue-600 text-white px-6 py-2 rounded-full font-bold hover:bg-blue-700 transition text-sm">
            Ver Rutas
        </button>
            <button id="btnDestrazar" class="bg-red-600 text-white px-6 py-2 rounded-full font-bold hover:bg-red-700 transition text-sm">
            Limpiar
        </button>
        </div>
    </div>

    <div id="contenedorCards" class="hidden mb-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (arrayRutas.length > 0) { %>
                <% arrayRutas.forEach(ruta => { %>
                    <div class="cursor-pointer bg-white rounded-xl shadow-sm hover:shadow-lg transition-all border border-slate-200 overflow-hidden" onclick="cargarRutaDesdeCard('<%= ruta.localizacion_map %>')">
                        <div class="h-40 bg-slate-100 relative">
                            <iframe src="<%= ruta.localizacion_map %>" width="100%" height="100%" style="border:0; pointer-events: none;"></iframe>
                            <div class="absolute inset-0 bg-transparent"></div>
                        </div>
                        <div class="p-4">
                            <span class="font-bold text-slate-800"><%= ruta.nombreRuta %></span>
                        </div>
                    </div>
                    <% }) %>
                        <% } %>
        </div>
    </div>

    <div id="contenedorMapaPrincipal" class="hidden w-100 rounded-xl overflow-hidden shadow-lg border border-slate-200">
        <iframe id="mapaIframe" src="about:blank" width="100%" height="800" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
    </div>


    <script>
        const selectRuta = document.getElementById('selectRuta');
        const mapaIframe = document.getElementById('mapaIframe');
        const contenedorMapaPrincipal = document.getElementById('contenedorMapaPrincipal');
        const contenedorCards = document.getElementById('contenedorCards');
        const btnVerCards = document.getElementById('btnVerCards');
        const btnDestrazar = document.getElementById('btnDestrazar');

        // Función unificada para mostrar el mapa grande
        function mostrarMapaGrande(url) {
            if (url && url !== "" && url !== "about:blank") {
                mapaIframe.src = url;
                contenedorMapaPrincipal.classList.remove('hidden'); // Muestra el div

                // Opcional: Desplazar la vista al mapa
                setTimeout(() => {
                    contenedorMapaPrincipal.scrollIntoView({
                        behavior: 'smooth'
                    });
                }, 200);
            } else {
                mapaIframe.src = "about:blank";
                contenedorMapaPrincipal.classList.add('hidden'); // Oculta si no hay URL
            }
        }

        // Función global para las Cards (necesaria para el onclick)
        window.cargarRutaDesdeCard = function(url) {
            selectRuta.value = url; // Sincroniza el select
            mostrarMapaGrande(url);
        };

        // Evento al cambiar el Select
        selectRuta.addEventListener('change', function() {
            mostrarMapaGrande(this.value);
        });

        // Evento para el botón "Ver Rutas" (Mostrar/Ocultar catálogo de cards)
        btnVerCards.addEventListener('click', function() {
            if (contenedorCards.classList.contains('hidden')) {
                contenedorCards.classList.remove('hidden');
                this.textContent = "Ocultar Rutas";
                this.classList.replace('bg-blue-600', 'bg-slate-600');
            } else {
                contenedorCards.classList.add('hidden');
                this.textContent = "Ver Rutas";
                this.classList.replace('bg-slate-600', 'bg-blue-600');
            }
        });

        // Botón Limpiar/Destrazar
        btnDestrazar.addEventListener('click', function() {
            selectRuta.value = "";
            mostrarMapaGrande("");
            contenedorCards.classList.add('hidden'); // Opcional: oculta las cards también
            btnVerCards.textContent = "Ver Rutas";
            btnVerCards.classList.replace('bg-slate-600', 'bg-blue-600');
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    </script>












    <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
    <a href="/encuestas-metricas-usuario" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 m-4 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
    </div>


    <script>
        $(document).ready(function() {
            $('#datatable2').DataTable({
                order: [
                    [0, 'desc']
                ],


                language: {
                    "decimal": "",
                    "emptyTable": "No hay información",
                    "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                    "infoEmpty": "Mostrando 0 to 0 of 0 Entradas",
                    "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                    "infoPostFix": "",
                    "thousands": ",",
                    "lengthMenu": "Mostrar _MENU_ Entradas",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "search": "Buscar:",
                    "zeroRecords": "Sin resultados encontrados",
                    "paginate": {
                        "first": "Primero",
                        "last": "Ultimo",
                        "next": "Siguiente",
                        "previous": "Anterior"
                    }
                }
            });

        });
    </script>



</body>

