<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- css y js bootstrap cdn -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.min.js"></script>
    <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script> -->
    <!-- linkeado css propio -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- icons bootstrap cdn -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.3/font/bootstrap-icons.css">
    <!-- generador de pdf cdn -->
    <!-- <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" integrity="sha512-GsLlZN/3F2ErC5ifS5QtgpiJtWd43JWSuIgh7mbzZ8zBps+dvLusV+eNQATqgA/HdeKFVgA5v3S/cIrLF7QnIg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script> -->
    <!-- moment.js cdn -->
    <!-- <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.3/moment-with-locales.min.js"></script>s -->
    <!-- DATATABLE -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://cdn.datatables.net/1.12.1/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.3.0/js/dataTables.responsive.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.12.1/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.3.0/css/responsive.dataTables.min.css">
    <link rel="icon" href="/img/favicon/logo-favicon.png">
    <title>Rosfal - Editar Usuario App</title>
</head>


<body>

    <div class="whatsapp">
        <a class="btn-ws " href="https://bit.ly/4co7WFg" target="_blank"><img class="img-fluid" src="/img/logo-ws.png" alt="logo ws"></a>
    </div>

    <nav class="navbar navbar-expand-lg navbar-light  ">
        <div class="container-fluid  " style="">
            <div class="w-100 m-2 d-flex justify-content-between align-items-center">

                <a href="/panel-administracion">

                    <i class="bi bi-arrow-left fs-4"></i>
                </a>

                <div class="w-100 d-flex justify-content-center">

                    <p class="m-0">Promociones</p>
                </div>
            </div>

        </div>
    </nav>



    <div class="p-3">
        <div style="border-radius: 20px; background-color: white;" class="container-fluid p-4 shadow-sm border-0">
            <div class="text-center mb-4">
                <h5 class="text-muted fw-normal">HOLA,
                    <span class="text-primary fw-bold">
                    <% if (SolicitudesCliente.length > 0) { %>
                        <% SolicitudesCliente.forEach(SolicitudesCliente => { %>
                            <% if(SolicitudesCliente.celular == usuario.user){ %>
                                <%= SolicitudesCliente.nombre %>
                            <% } %>
                        <% }) %>
                    <% } else { %>
                        <%= name %>
                    <% } %>
                </span>
                </h5>
                <hr class="mx-5 opacity-0">
            </div>

            <div class="text-center">
                <img width="80px" src="/img/reporte-de-negocios.png" class="mb-3" alt="Promo">
                <h3 class="fw-bold">Comparte tu código</h3>
                <p class="text-secondary px-lg-5">
                    Obtén <span class="text-success fw-bold">RD$250</span> por cada recomendado.
                    <br>¡Ellos también recibirán <span class="text-success fw-bold">RD$250</span> en su primer préstamo!
                </p>

                <div class="mt-4 p-4 rounded-3 border-dashed border-2 border-primary bg-light" style="border-style: dashed !important;">
                    <span class="text-muted small text-uppercase fw-bold">Tu código exclusivo es:</span>
                    <h2 class="display-6 fw-bold text-primary mb-0 mt-2">
                        <% let codigo_promo = usuario.idUsuario.toString() + cliente.cliente_id.toString() %>
                            <%= codigo_promo %>-PRIMERCREDITO
                    </h2>
                </div>
            </div>
        </div>

        <div class="mt-4 row g-2">
            <div class="col-12">
                <a class="btn btn-success btn-lg w-100 d-flex align-items-center justify-content-center py-3 shadow-sm" style="border-radius: 15px;" target="_blank" href="https://wa.me/?text=%0A*INVITACIÓN ESPECIAL A ROSFAL SOLUCIONES DE PRÉSTAMOS*%0A%0AEstimad@ cliente, le han extendido una invitación especial para registrarse en Rosfal Soluciones de Préstamos.%0A%0AUna vez completado su registro, obtendrás un descuento exclusivo y trato preferencial en su primer préstamo.%0A%0A*Código de invitación:*%0A<%= usuario.idUsuario %><%= cliente.cliente_id %>-PRIMERCREDITO%0A%0A*Para más información:*%0A*Email:* contacto@rosfal.com%0A*WhatsApp:* 829 856-0203%0A*Regístrese aquí:* https://www.rosfal.com/app-inicio">
                    <i class="bi bi-whatsapp me-2 fs-4"></i> <strong>Compartir mi código</strong>
                </a>
            </div>

            <div class="col-12 mt-2 text-center">
                <button type="button" style="border-radius: 15px;" class="btn btn-outline-warning text-dark w-100 py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#staticBackdrop2">
                <i class="bi bi-qr-code-scan me-2"></i> CARGAR CÓDIGO PROMOCIÓN
            </button>
            </div>
        </div>

        <div class="modal fade" id="staticBackdrop2" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow" style="border-radius: 20px;">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title w-100 text-center fw-bold mt-2">Cargar código promoción</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form id="form-validacion" autocomplete="off" action="" method="POST">
                        <div class="modal-body p-4">
                            <div class="form-floating mb-3">
                                <input style="text-transform:uppercase" class="form-control bg-light border-0 text-center fs-4 fw-bold text-primary" type="text" name="codigo_promocion" id="codigoInput" placeholder="CODIGO123" required>
                                <label for="codigoInput" class="w-100 text-center">Escribe el código aquí</label>
                            </div>
                            <p class="text-center text-muted small px-3">El crédito se aplicará automáticamente tras validar el código.</p>
                        </div>
                        <div class="modal-footer border-0 p-4 pt-0">
                            <button class="btn btn-warning w-100 py-3 fw-bold shadow-sm" style="border-radius: 15px;" type="submit">
                            GUARDAR CÓDIGO
                        </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid  mt-3">
        <div class="container-fluid p-1">
            <h3 class="text-secondary"><strong>LISTADO</strong> DE PROMOCIONES</h3>
            <div class="container-fluid p-4">
                <div class="container-table table-responsive">
                    <table id="datatable" class="display responsive nowrap compact" style="width:100%">
                        <thead class="thead-ligth">
                            <tr>
                                <th scope="col">Promocion</th>
                                <th scope="col">Valor Acreditado</th>
                                <th scope="col">Fecha Registro</th>

                                <th scope="col">Origen Bono</th>
                                <th scope="col">Estado</th>

                            </tr>
                        </thead>
                        <tbody>
                            <% if (promocionesCliente.length > 0) { %>
                                <% promocionesCliente.forEach(promocion=> { %>
                                    <tr>
                                        <td>
                                            <%= promocion.codigo_promocion %>
                                        </td>
                                        <td>
                                            <%= promocion.valor_credito=Intl.NumberFormat('en-EN', { style: 'currency' , currency: 'USD' }).format(promocion.valor_credito) %>
                                        </td>
                                        <td>
                                            <%= promocion.fecha_registro.toLocaleString('es-US', { timeZone: "America/Santo_Domingo"}) %>
                                        </td>

                                        <td>
                                            <%= promocion.origen_bono %>
                                        </td>
                                        <td>
                                            <% if(promocion.estado_promocion == 'Aprobado' ) { %>
                                                <i style="color: green;" class="bi bi-check-square-fill"></i>
                                                <%= promocion.estado_promocion  %>

                                                    <% }else { %>
                                                        <span style="color: #f85e5e;"><i class="bi bi-x-square-fill"></i> <%= promocion.estado_promocion  %></span>
                                                        <% } %>
                                        </td>

                                    </tr>


                                    <% }) %>
                                        <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>



    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if (typeof alert !== "undefined") { %>
        <script>
            Swal.fire({
                title: "<%= alertTitle %>",
                text: "<%= alertMessage %>",
                icon: "<%= alertIcon %>",
                showConfirmButton: <%= showConfirmButton %>,
                timer: <%= timer %>
            }).then(() => {
                window.location.href = "<%= ruta %>";
            });
        </script>
        <% } %>


            <% if (rol == 'Cliente App'){ %>
                <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100">
                    <a href="/panel-administracion" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
                </div>
                <% } %>



                    <script>
                        $(document).ready(function() {
                            $('#datatable').DataTable({
                                order: [
                                    [3, 'desc']
                                ],
                                language: {
                                    "decimal": "",
                                    "emptyTable": "No hay información",
                                    "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                                    "infoEmpty": "Mostrando 0 to 0 of 0 Entradas",
                                    "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                                    "infoPostFix": "",
                                    "thousands": ",",
                                    "lengthMenu": "Mostrar _MENU_ Entradas",
                                    "loadingRecords": "Cargando...",
                                    "processing": "Procesando...",
                                    "search": "Buscar:",
                                    "zeroRecords": "Sin resultados encontrados",
                                    "paginate": {
                                        "first": "Primero",
                                        "last": "Ultimo",
                                        "next": "Siguiente",
                                        "previous": "Anterior"
                                    }
                                }
                            });
                        });
                    </script>



</body>

</html>