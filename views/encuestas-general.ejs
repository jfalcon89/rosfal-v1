    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8 overflow-y-auto ">

        <!-- Potenciales Clientes Table -->
        <div class="card mb-5 border-0">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-slate-800 text-lg">Ranking de Prospectos Potenciales</h3>
                <span class="text-xs bg-blue-100 text-blue-600 px-2 py-1 rounded font-bold">ACTUALIZADO AHORA</span>
            </div>
            <div style="border-radius: 50px; box-shadow:  20px 20px 60px #bebebe, -20px -20px 60px #ffffff;" class="container-fluid p-4">
                <div class="overflow-x-auto">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label>Filtrar por Ruta:</label>
                            <select id="filtroRuta" class="form-control">
                             <option value="">Todas las rutas</option>
                             <% if (arrayRutas.length > 0) { %>
                                 <% arrayRutas.forEach(ruta => { %>
                                     <option value="<%= ruta.nombreRuta %>"><%= ruta.nombreRuta %></option>
                                 <% }) %>
                             <% } %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label>Filtrar por Encuestador:</label>
                            <select id="filtroEncuestador" class="form-control">
                                <option value="">Todos los encuestadores</option>
                                         <% if (arrayUser.length > 0) { %>
                                         <% arrayUser.forEach(user => { %>
                                     <option value="<%= user.name %>"><%= user.name %></option>
                                 <% }) %>
                             <% } %>

                            </select>
                        </div>
                        <div class="col-md-3">
                            <label>Filtrar por tipo:</label>
                            <select id="filtroTipo" class="form-control">
                                <option value="">Todos los Tipos</option>
                                <option value="Salón de Belleza">Salón de Belleza</option>
                                <option value="Peluquería">Peluquería</option>
                                <option value="Colmado">Colmado</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <div class="d-flex mb-3">
                                <div class="me-2">
                                    <label>Desde:</label>
                                    <input style="width: auto;" type="date" id="min" class="form-control">
                                </div>
                                <div class="">
                                    <label>Hasta:</label>
                                    <input style="width: auto;" type="date" id="max" class="form-control">
                                </div>
                            </div>
                        </div>
                    </div>
                    <table id="datatable" class="w-full text-left min-w-[600px] ">
                        <thead>
                            <tr class="text-slate-400 text-sm border-b">
                                <th class="pb-3 font-semibold">ID</th>
                                <th class="pb-3 font-semibold">NEGOCIO</th>
                                <th class="pb-3 font-semibold">TIPO</th>
                                <th class="pb-3 font-semibold">OTRO</th>
                                <th class="pb-3 font-semibold">RUTA</th>
                                <th class="pb-3 font-semibold">UBICACION CALLE</th>
                                <th class="pb-3 font-semibold text-center">AÑOS OPERACIONES</th>
                                <th class="pb-3 font-semibold text-center">FLUJO CLIENTES</th>
                                <th class="pb-3 font-semibold">PRIORIDAD</th>
                                <th class="pb-3 font-semibold">FRECUENCIA CAPITAL</th>
                                <th class="pb-3 font-semibold text-center">SATISF. OTROS PRESTAMOS</th>
                                <th class="pb-3 font-semibold">ENCUESTADOR</th>
                                <th class="pb-3 font-semibold">CREADO</th>
                                <th class="pb-3 font-semibold text-center">SCORE POTENCIAL</th>
                                <th class="pb-3 font-semibold text-center">ES POTENCIAL</th>
                                <% const Eliminar_Encuesta = (config.Eliminar_Encuesta || []).includes(rol); %>
                                    <% if (Eliminar_Encuesta) { %>
                                        <th class="pb-3 font-semibold text-center">ACCION</th>
                                        <% } %>
                            </tr>
                        </thead>
                        <tbody class="text-slate-700">
                            <% if (arrayEncuestas.length > 0) { %>
                                <% arrayEncuestas.forEach(encuesta=> { %>

                                    <tr class="border-b hover:bg-slate-50 transition-colors">
                                        <td class="py-4 text-sm">
                                            <%= encuesta.id_encuesta %>
                                        </td>
                                        <td class="py-4">
                                            <div class="font-bold">
                                                <%= encuesta.negocio_nombre %>
                                            </div>
                                            <div class=" text-slate-400">
                                                <%= encuesta.encargado_nombre %>
                                            </div>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.tipo_negocio %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.tipo_negocio_otro %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.ruta %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <a href="<%= encuesta.ubicacion_calle %>" target="_blank">
                                                <%= encuesta.ubicacion_calle %>
                                            </a>

                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.anos_operacion %>
                                        </td>
                                        <td class="py-4">
                                            <div class="flex justify-center">
                                                <span class="px-2 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold"><%= encuesta.flujo_clientes_score %> / 10</span>
                                            </div>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.prioridad_inversion %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.frecuencia_capital %>
                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.satisfaccion_prestamos_actuales %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.encuestador %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.creado_el.toLocaleString('es-US', { timeZone: "America/Santo_Domingo"}).slice(0, 10) %>
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="px-3 py-1 rounded-full score-high font-bold text-sm"><%= encuesta.score_potencial %> pts</span>
                                        </td>
                                        <td class="py-4  text-center">
                                            <% if(encuesta.es_potencial == 'SI'){ %>
                                                <i style="color: green;" class="bi bi-check-square-fill"></i>
                                                <span class=" "><%= encuesta.es_potencial %></span>
                                                <% }else{ %>
                                                    <span style="color: #f85e5e;"><i class="bi bi-x-square-fill"></i>
                                                        <span class=""><%= encuesta.es_potencial %></span>
                                                    <% } %>
                                        </td>
                                        <% if (Eliminar_Encuesta) { %>
                                            <td class="py-4 text-center ">
                                                <a href="javascript:void(0)" onclick="confirmarBaja('<%= encuesta.id_encuesta %>')" class="btn btn-sm btn-outline-danger"><i  class="bi bi-x-square-fill"></i></a>
                                            </td>
                                            <% } %>
                                    </tr>

                                    <% }) %>
                                        <% } %>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>

    <script>
        function confirmarBaja(id) {
            Swal.fire({
                title: '¿Eliminar Encuesta?',
                text: "Esta acción no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2563eb', // Azul Rosfal
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // SI CONFIRMA: Recién aquí viajamos al servidor para borrar
                    window.location = '/encuestas-general/eliminar-encuesta/' + id;
                }
                // SI CANCELA: No pasa nada, el modal se cierra y no hay recarga
            });
        }
    </script>


    <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
    <a href="/panel-administracion" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 m-4 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
    </div>


    <script>
        $(document).ready(function() {
            $('#datatable').DataTable({
                order: [
                    [0, 'desc']
                ],
                // 'B' para botones, 'l' para el selector de cantidad (lengthMenu)
                dom: 'Blfrtip',
                buttons: [{
                    extend: 'excel',
                    text: 'Exportar a Excel',
                    className: 'btn btn-success' // Opcional: clase CSS para estilo
                }, {
                    extend: 'pdfHtml5',
                    orientation: 'landscape',
                    pageSize: 'LEGAL',
                    text: 'Exportar a PDF',
                    className: 'btn btn-danger' // Opcional: clase CSS para estilo
                }],
                language: {
                    "decimal": "",
                    "emptyTable": "No hay información",
                    "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                    "infoEmpty": "Mostrando 0 a 0 de 0 Entradas",
                    "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                    "infoPostFix": "",
                    "thousands": ",",
                    "lengthMenu": "Mostrar _MENU_ Entradas",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "search": "Buscar:",
                    "zeroRecords": "Sin resultados encontrados",
                    "paginate": {
                        "first": "Primero",
                        "last": "Ultimo",
                        "next": "Siguiente",
                        "previous": "Anterior"
                    }
                },

            });
            // Lógica de filtrado por Ruta (Columna índice 4)
            $('#filtroRuta').on('change', function() {
                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                $('#datatable').DataTable().column(4).search(val ? '^' + val + '$' : '', true, false).draw();
            });

            // Lógica de filtrado por Cobrador (Columna índice 11)
            $('#filtroEncuestador').on('change', function() {
                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                $('#datatable').DataTable().column(11).search(val ? '^' + val + '$' : '', true, false).draw();
            });
            // Lógica de filtrado por tipo (Columna índice 2)
            $('#filtroTipo').on('change', function() {
                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                $('#datatable').DataTable().column(2).search(val ? '^' + val + '$' : '', true, false).draw();
            });
            // 1. Definimos la función de filtrado personalizada
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var min = $('#min').val(); // Formato: YYYY-MM-DD
                    var max = $('#max').val(); // Formato: YYYY-MM-DD

                    // 1. Obtenemos el texto de la columna 7
                    var rawData = data[12] || "";
                    if (rawData === "") return true;

                    // 2. LIMPIEZA: Extraemos solo la parte de la fecha (lo que esté antes de la coma o el espacio)
                    // Si sale "2022, 12:48:07 p. m.-9-6", necesitamos extraer los números.
                    // Lo más seguro es usar una expresión regular para sacar día, mes y año.
                    var dateMatches = rawData.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);

                    if (!dateMatches) {
                        // Intento alternativo si el formato viene separado por espacios o comas
                        // Esto limpia casos raros de toLocaleString()
                        var cleanDate = rawData.split(',')[0].trim();
                        dateMatches = cleanDate.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
                    }

                    if (dateMatches) {
                        var day = dateMatches[1].padStart(2, '0');
                        var month = dateMatches[2].padStart(2, '0');
                        var year = dateMatches[3];

                        // 3. Formateamos a YYYY-MM-DD para comparar
                        var dateComparable = year + '-' + month + '-' + day;

                        // 4. Comparación lógica
                        if (
                            (min === "" && max === "") ||
                            (min === "" && dateComparable <= max) ||
                            (min <= dateComparable && max === "") ||
                            (min <= dateComparable && dateComparable <= max)
                        ) {
                            return true;
                        }
                    }

                    return false;
                }
            );

            // 2. Eventos para redibujar la tabla al cambiar las fechas
            $(document).ready(function() {
                // Asegúrate de que esta variable 'table' coincida con la inicialización de tu DataTable
                var table = $('#datatable').DataTable();

                $('#min, #max').on('change', function() {
                    table.draw();
                });
            });
        });
    </script>



</body>

