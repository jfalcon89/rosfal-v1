<body style="background-color: white;">

    <nav class="flex items-center justify-between px-4 py-2 bg-gradient-to-r from-[#eaf6ff] to-[#a5d3ff] rounded-b-[15px] shadow-sm">
        <div class="flex items-center space-x-3">
            <img src="/img/LOGO-ROSFAL.png" alt="logo-rosfal" class="w-[80px]">
            <h5 class="text-gray-800 font-semibold text-lg uppercase tracking-wider">Encuestas</h5>
        </div>

        <button class="lg:hidden text-gray-600 focus:outline-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m4 6h16"></path>
        </svg>
    </button>

        <div class="hidden lg:flex items-center space-x-4">
            <div class="flex items-center bg-white/40 px-4 py-1 rounded-full border border-blue-200">
                <i class="bi bi-person-square text-[30px] text-blue-600 mr-3"></i>
                <% if (login) { %>
                    <div class="leading-tight">
                        <h4 class="text-sm font-bold text-gray-700 uppercase">
                            <%= name %>
                        </h4>
                        <h6 class="text-xs text-blue-800 font-medium">
                            <%= rol %>
                        </h6>
                    </div>
                    <% } %>
            </div>

            <button class="p-2 hover:bg-blue-100 rounded-full transition-colors" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas">
            <i class="bi bi-list text-2xl"></i>
        </button>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start !border-none !rounded-r-2xl shadow-2xl" tabindex="-1" id="navbarOffcanvas" aria-labelledby="navbarOffcanvasLabel">
        <div class="flex items-center justify-between p-4 border-b border-gray-100">
            <h5 class="text-blue-900 font-bold text-lg italic" id="navbarOffcanvasLabel">ROSFAL MENU</h5>
            <button type="button" class="text-gray-400 hover:text-black transition-colors" data-bs-dismiss="offcanvas">
            <i class="bi bi-x-lg text-xl"></i>
        </button>
        </div>

        <div class="p-4">
            <div class="flex items-center p-3 bg-gray-50 rounded-xl mb-6">
                <% if (login) { %>
                    <i class="bi bi-person-square text-[40px] text-gray-400 mr-4"></i>
                    <div>
                        <h4 class="text-gray-600 font-bold text-base leading-none mb-1">
                            <%= name %>
                        </h4>
                        <p class="text-xs text-gray-400 uppercase tracking-tighter">
                            <%= rol %>
                        </p>
                    </div>
                    <% } %>
            </div>

            <div class="space-y-2">
                <%- include('template/navbar-menu') %>
            </div>
        </div>
    </div>

    <div class=" p-2 d-lg-flex flex-sm-row mt-4 " style="background-color: #ececec;">
        <div class="container-fluid mt-3 mb-3 me-lg-3 d-flex holographic-card bg-white" style=" border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📊</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3 style="color: #2f6eaa;">
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo">
                        <a style="color: #2f6eaa;" class="text-decoration-none fs-5" href="/encuestas-administracion">
                                 Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid  mt-3 mb-3 me-lg-3 d-flex holographic-card" style="background-color: #d4d4d4; border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📝</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h1>
                            <%=  %>
                        </h1>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/encuestas-general">Encuestas Realizadas</a></div>
                </div>
            </div>
        </div>
        <div class="container-fluid bg-white mt-3 mb-3 me-lg-3 d-flex holographic-card" style="border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📍</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3>
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/mapa-rutas">Mapas de Rutas</a></div>
                </div>
            </div>
        </div>
        <div class="container-fluid bg-white mt-3 me-lg-3 mb-3 d-flex holographic-card" style="border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">⚙️</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3>
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/rutas">Configuración</a></div>
                </div>
            </div>
        </div>
    </div>


    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8 overflow-y-auto ">

        <!-- Potenciales Clientes Table -->
        <div class="card mb-5 border-0">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-slate-800 text-lg">Ranking de Prospectos Potenciales</h3>
                <span class="text-xs bg-blue-100 text-blue-600 px-2 py-1 rounded font-bold">ACTUALIZADO AHORA</span>
            </div>
            <div style="border-radius: 50px; box-shadow:  20px 20px 60px #bebebe, -20px -20px 60px #ffffff;" class="container-fluid p-4">
                <div class="overflow-x-auto">
                    <table id="datatable2" class="w-full text-left min-w-[600px] ">
                        <thead>
                            <tr class="text-slate-400 text-sm border-b">
                                <th class="pb-3 font-semibold">ID</th>
                                <th class="pb-3 font-semibold">NEGOCIO</th>
                                <th class="pb-3 font-semibold">TIPO</th>
                                <th class="pb-3 font-semibold">OTRO</th>
                                <th class="pb-3 font-semibold">RUTA</th>
                                <th class="pb-3 font-semibold">UBICACION CALLE</th>
                                <th class="pb-3 font-semibold text-center">AÑOS OPERACIONES</th>
                                <th class="pb-3 font-semibold text-center">FLUJO CLIENTES</th>
                                <th class="pb-3 font-semibold">PRIORIDAD</th>
                                <th class="pb-3 font-semibold">FRECUENCIA CAPITAL</th>
                                <th class="pb-3 font-semibold text-center">SATISF. OTROS PRESTAMOS</th>
                                <th class="pb-3 font-semibold">ENCUESTADOR</th>
                                <th class="pb-3 font-semibold">CREADO</th>
                                <th class="pb-3 font-semibold text-center">SCORE POTENCIAL</th>
                                <th class="pb-3 font-semibold text-center">ES POTENCIAL</th>
                                <th class="pb-3 font-semibold text-center">ACCION</th>
                            </tr>
                        </thead>
                        <tbody class="text-slate-700">
                            <% if (arrayEncuestas.length > 0) { %>
                                <% arrayEncuestas.forEach(encuesta=> { %>

                                    <tr class="border-b hover:bg-slate-50 transition-colors">
                                        <td class="py-4 text-sm">
                                            <%= encuesta.id_encuesta %>
                                        </td>
                                        <td class="py-4">
                                            <div class="font-bold">
                                                <%= encuesta.negocio_nombre %>
                                            </div>
                                            <div class=" text-slate-400">
                                                <%= encuesta.encargado_nombre %>
                                            </div>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.tipo_negocio %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.tipo_negocio_otro %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.ruta %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <a href="<%= encuesta.ubicacion_calle %>" target="_blank">
                                                <%= encuesta.ubicacion_calle %>
                                            </a>

                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.anos_operacion %>
                                        </td>
                                        <td class="py-4">
                                            <div class="flex justify-center">
                                                <span class="px-2 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold"><%= encuesta.flujo_clientes_score %> / 10</span>
                                            </div>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.prioridad_inversion %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.frecuencia_capital %>
                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.satisfaccion_prestamos_actuales %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.encuestador %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.creado_el.toLocaleString('es-US', { timeZone: "America/Santo_Domingo"}).slice(0, 10) %>
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="px-3 py-1 rounded-full score-high font-bold text-sm"><%= encuesta.score_potencial %> pts</span>
                                        </td>
                                        <td class="py-4  text-center">
                                            <% if(encuesta.es_potencial == 'SI'){ %>
                                                <i style="color: green;" class="bi bi-check-square-fill"></i>
                                                <span class=" "><%= encuesta.es_potencial %></span>
                                                <% }else{ %>
                                                    <span style="color: #f85e5e;"><i class="bi bi-x-square-fill"></i>
                                                        <span class=""><%= encuesta.es_potencial %></span>
                                                    <% } %>
                                        </td>
                                        <td class="py-4 text-center">
                                            <a href="javascript:void(0)" onclick="confirmarBaja('<%= encuesta.id_encuesta %>')" class="btn-delete">Eliminar</a>
                                        </td>
                                    </tr>

                                    <% }) %>
                                        <% } %>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>

    <script>
        function confirmarBaja(id) {
            Swal.fire({
                title: '¿Eliminar Encuesta?',
                text: "Esta acción no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2563eb', // Azul Rosfal
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // SI CONFIRMA: Recién aquí viajamos al servidor para borrar
                    window.location = '/encuestas-general/eliminar-encuesta/' + id;
                }
                // SI CANCELA: No pasa nada, el modal se cierra y no hay recarga
            });
        }
    </script>


    <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
    <a href="/panel-administracion" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 m-4 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
    </div>


    <script>
        $(document).ready(function() {
            $('#datatable2').DataTable({
                order: [
                    [0, 'desc']
                ],


                language: {
                    "decimal": "",
                    "emptyTable": "No hay información",
                    "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                    "infoEmpty": "Mostrando 0 to 0 of 0 Entradas",
                    "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                    "infoPostFix": "",
                    "thousands": ",",
                    "lengthMenu": "Mostrar _MENU_ Entradas",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "search": "Buscar:",
                    "zeroRecords": "Sin resultados encontrados",
                    "paginate": {
                        "first": "Primero",
                        "last": "Ultimo",
                        "next": "Siguiente",
                        "previous": "Anterior"
                    }
                }
            });

        });
    </script>



</body>

</html>