<body style="background-color: white;">

    <nav class="navbar navbar-expand-lg navbar-light" style="background: linear-gradient(to right, #eaf6ff, #a5d3ff); border-radius: 0px 0px 15px 15px;">
        <div class="container-fluid  ">

            <div class="d-flex">
                <img src="/img/LOGO-ROSFAL.png" alt="logo-rosfal" style="width: 80px;" class="me-2">
                <h5 class="text-dark m-2 d-flex align-items-center" style="font-size: large;">SOLICITUDES</h5>
            </div>
            <button class="navbar-toggler  " type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas" aria-controls="navbarOffcanvas" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <div class="offcanvas-body ">

                    <div class="d-flex">
                        <div class="btn-group ">
                            <button type="button" class="hola navbar-toggler d-block me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas" aria-controls="navbarOffcanvas" aria-expanded="false" aria-label="Toggle navigation">
                                <span class="navbar-toggler-icon show "></span>
                            </button>
                            <i class="bi bi-person-square me-2" style="font-size: 40px;"></i>
                        </div>
                        <div class="user-container me-2 d-flex">
                            <% if (login) { %>
                                <div>
                                    <h4 type="" class="">
                                        <%= name %>
                                    </h4>
                                    <h6>
                                        <%= rol %>
                                    </h6>
                                </div>
                                <%}  %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start" tabindex="100" id="navbarOffcanvas" aria-labelledby="navbarOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="navbarOffcanvasLabel">
                <h5 class="text-dark m-2" style="font-size: large;">SOLICITUDES</h5>
            </h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div class="user-container me-2 d-flex align-content-center" style="background-color: #ececec;">
                <% if (login) { %>
                    <i class="bi bi-person-square me-2" style="font-size: 40px;"></i>
                    <div>
                        <h4 type="" class="" style="color: #aeaeae;">
                            <%= name %>
                        </h4>
                        <h6>
                            <%= rol %>
                        </h6>
                    </div>
                    <%}  %>
            </div>
            <hr class="dropdown-divider">
            <%- include('template/navbar-menu') %>
        </div>
    </div>

    <div class=" p-2 d-lg-flex flex-sm-row mt-4 " style="background-color: #ececec;">
        <div class="container-fluid mt-3 mb-3 me-lg-3 d-flex holographic-card bg-white" style=" border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📊</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3 style="color: #2f6eaa;">
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo">
                        <a style="color: #2f6eaa;" class="text-decoration-none fs-5" href="/encuestas-administracion">
                                 Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid  mt-3 mb-3 me-lg-3 d-flex holographic-card" style="background-color: #d4d4d4; border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📝</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h1>
                            <%=  %>
                        </h1>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/encuestas-general">Encuestas Realizadas</a></div>
                </div>
            </div>
        </div>
        <div class="container-fluid bg-white mt-3 mb-3 me-lg-3 d-flex holographic-card" style="border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">📍</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3>
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/solicitudes-declinadas">Mapas de Rutas</a></div>
                </div>
            </div>
        </div>
        <div class="container-fluid bg-white mt-3 me-lg-3 mb-3 d-flex holographic-card" style="border-radius: 50px;">
            <div class="container-nuevas d-flex">
                <div class="container-img m-2 me-lg-3">
                    <span style="font-size:50px ">⚙️</span>
                </div>
                <div class="container-titulo d-flex align-items-center">
                    <div class="indicador">
                        <h3>
                            <%=  %>
                        </h3>
                    </div>
                    <div class="titulo"><a class="text-decoration-none text-secondary fs-5" href="/solicitudes-en-revision">Configuración</a></div>
                </div>
            </div>
        </div>
    </div>


    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8 overflow-y-auto ">

        <!-- Potenciales Clientes Table -->
        <div class="card mb-5 border-0">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-slate-800 text-lg">Ranking de Prospectos Potenciales</h3>
                <span class="text-xs bg-blue-100 text-blue-600 px-2 py-1 rounded font-bold">ACTUALIZADO AHORA</span>
            </div>
            <div style="border-radius: 50px; box-shadow:  20px 20px 60px #bebebe, -20px -20px 60px #ffffff;" class="container-fluid p-4">
                <div class="overflow-x-auto">
                    <table id="datatable2" class="w-full text-left min-w-[600px] ">
                        <thead>
                            <tr class="text-slate-400 text-sm border-b">
                                <th class="pb-3 font-semibold">ID</th>
                                <th class="pb-3 font-semibold">NEGOCIO</th>
                                <th class="pb-3 font-semibold">TIPO</th>
                                <th class="pb-3 font-semibold">OTRO</th>
                                <th class="pb-3 font-semibold">RUTA</th>
                                <th class="pb-3 font-semibold">UBICACION CALLE</th>
                                <th class="pb-3 font-semibold text-center">AÑOS OPERACIONES</th>
                                <th class="pb-3 font-semibold text-center">FLUJO CLIENTES</th>
                                <th class="pb-3 font-semibold">PRIORIDAD</th>
                                <th class="pb-3 font-semibold">FRECUENCIA CAPITAL</th>
                                <th class="pb-3 font-semibold text-center">SATISF. OTROS PRESTAMOS</th>
                                <th class="pb-3 font-semibold">ENCUESTADOR</th>
                                <th class="pb-3 font-semibold">CREADO</th>
                                <th class="pb-3 font-semibold text-center">SCORE POTENCIAL</th>
                                <th class="pb-3 font-semibold text-center">ES POTENCIAL</th>
                            </tr>
                        </thead>
                        <tbody class="text-slate-700">
                            <% if (arrayEncuestas.length > 0) { %>
                                <% arrayEncuestas.forEach(encuesta=> { %>

                                    <tr class="border-b hover:bg-slate-50 transition-colors">
                                        <td class="py-4 text-sm">
                                            <%= encuesta.id_encuesta %>
                                        </td>
                                        <td class="py-4">
                                            <div class="font-bold">
                                                <%= encuesta.negocio_nombre %>
                                            </div>
                                            <div class="text-xs text-slate-400">
                                                <%= encuesta.encargado_nombre %>
                                            </div>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.tipo_negocio %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.tipo_negocio_otro %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.ruta %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.ubicacion_calle %>
                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.anos_operacion %>
                                        </td>
                                        <td class="py-4">
                                            <div class="flex justify-center">
                                                <span class="px-2 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold"><%= encuesta.flujo_clientes_score %> / 10</span>
                                            </div>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.prioridad_inversion %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.frecuencia_capital %>
                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.satisfaccion_prestamos_actuales %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.encuestador %>
                                        </td>
                                        <td class="py-4 text-sm">
                                            <%= encuesta.creado_el.toLocaleString('es-US', { timeZone: "America/Santo_Domingo"}).slice(0, 10) %>
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="px-3 py-1 rounded-full score-high font-bold text-sm"><%= encuesta.score_potencial %> pts</span>
                                        </td>
                                        <td class="py-4 text-sm text-center">
                                            <%= encuesta.es_potencial %>
                                        </td>
                                    </tr>

                                    <% }) %>
                                        <% } %>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>




    <div style="padding-bottom: 10px;" class="d-flex justify-content-center w-100"></div>
    <a href="/panel-administracion" style="text-align: center; color: #014c90; text-decoration: none;" type="submit" class=" p-2 m-4 w-100" id="btn-info"><i class="bi bi-arrow-left-circle me-2"></i>Regresar atras</a>
    </div>


    <script>
        $(document).ready(function() {
            $('#datatable2').DataTable({
                order: [
                    [0, 'desc']
                ],


                language: {
                    "decimal": "",
                    "emptyTable": "No hay información",
                    "info": "Mostrando _START_ a _END_ de _TOTAL_ Entradas",
                    "infoEmpty": "Mostrando 0 to 0 of 0 Entradas",
                    "infoFiltered": "(Filtrado de _MAX_ total entradas)",
                    "infoPostFix": "",
                    "thousands": ",",
                    "lengthMenu": "Mostrar _MENU_ Entradas",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "search": "Buscar:",
                    "zeroRecords": "Sin resultados encontrados",
                    "paginate": {
                        "first": "Primero",
                        "last": "Ultimo",
                        "next": "Siguiente",
                        "previous": "Anterior"
                    }
                }
            });

        });
    </script>



</body>

</html>